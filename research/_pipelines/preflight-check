def check_disk_space() -> dict:
    """Check available disk space. BLOCKED if <100MB, WARNING if 100-500MB."""
    import os as _os
    try:
        st = _os.statvfs(RESEARCH_DIR if RESEARCH_DIR.exists() else Path.cwd())
        free_mb = (st.f_frsize * st.f_bavail) / (1024 * 1024)
    except (OSError, AttributeError) as e:
        return {"disk_check": "SKIPPED", "free_mb": None, "disk_warnings": [str(e)]}
    if free_mb < 100:
        return {"disk_check": "BLOCKED", "free_mb": round(free_mb, 1),
                "disk_warnings": [f"Only {free_mb:.0f} MB free. Free up disk space."]}
    elif free_mb < 500:
        return {"disk_check": "WARNING", "free_mb": round(free_mb, 1),
                "disk_warnings": [f"Only {free_mb:.0f} MB free. Clean up."]}
    return {"disk_check": "PASS", "free_mb": round(free_mb, 1)}


def check_python_deps() -> dict:
    """Check required Python deps can be imported."""
    import importlib.util
    missing = []
    for dep in ["ruamel.yaml", "yaml", "requests", "json", "os", "subprocess"]:
        spec = importlib.util.find_spec(dep.replace("-", "_").replace(".", ""))
        if spec is None:
            missing.append(dep)
    if missing:
        return {"deps_check": "BLOCKED", "missing_deps": missing,
                "deps_warnings": [f"Missing: {', '.join(missing)}. Install: pip install -r requirements.txt"]}
    return {"deps_check": "PASS", "missing_deps": []}


def ping_firecrawl() -> dict:
    """Check Firecrawl CLI connectivity (1-2 credits)."""
    import subprocess as _sp
    try:
        r = _sp.run(["firecrawl", "--version"], capture_output=True, text=True, timeout=15)
        if r.returncode != 0:
            return {"firecrawl_check": "WARNING", "firecrawl_version": None,
                    "firecrawl_warnings": ["CLI not responding."]}
        ver = r.stdout.strip() or r.stderr.strip() or "unknown"
    except FileNotFoundError:
        return {"firecrawl_check": "BLOCKED", "firecrawl_version": None,
                "firecrawl_warnings": ["CLI not found. Install from docs.firecrawl.dev."]}
    except _sp.TimeoutExpired:
        return {"firecrawl_check": "WARNING", "firecrawl_version": None,
                "firecrawl_warnings": ["--version timed out."]}
    try:
        sr = _sp.run(["firecrawl", "search", "sanity", "--limit", "1"],
                     capture_output=True, text=True, timeout=30)
        if sr.returncode != 0:
            return {"firecrawl_check": "WARNING", "firecrawl_version": ver,
                    "firecrawl_warnings": [f"Search failed: {sr.stderr.strip()[:200]}"]}
        return {"firecrawl_check": "PASS", "firecrawl_version": ver}
    except _sp.TimeoutExpired:
        return {"firecrawl_check": "WARNING", "firecrawl_version": ver,
                "firecrawl_warnings": ["Search timed out (>30s)."]}


def ping_mcp_servers() -> dict:
    """Check essential MCP configs in settings.json."""
    sp = Path.home() / ".claude" / "settings.json"
    if not sp.exists():
        return {"mcp_check": "WARNING", "mcp_warnings": ["settings.json not found."]}
    try:
        raw = load_yaml_safe(sp) or {}
    except (ValueError, OSError):
        raw = {}
    mcfg = raw.get("mcpServers", raw.get("mcp_servers", {}))
    expected = ["reddit-research", "open-registry", "context7"]
    found = [s for s in expected if s in mcfg]
    missing = [s for s in expected if s not in mcfg]
    if missing:
        return {"mcp_check": "WARNING", "found_servers": found, "missing_servers": missing,
                "mcp_warnings": [f"Not configured: {', '.join(missing)}. Optional."]}
    return {"mcp_check": "PASS", "found_servers": found}


