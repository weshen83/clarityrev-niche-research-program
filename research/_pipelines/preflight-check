def dead_host_write(niche_id: str, hostname: str, error_code: str) -> None:
    """Write to DEAD_HOST_REGISTRY after 3 consecutive failures (SRE-C06)."""
    rp = find_dead_host_registry()
    try:
        reg = load_yaml_safe(rp)
        if not isinstance(reg, dict) or "blocked_hosts" not in reg:
            reg = {"blocked_hosts": []}
        if not isinstance(reg["blocked_hosts"], list):
            reg["blocked_hosts"] = []
    except (ValueError, OSError):
        reg = {"blocked_hosts": []}
    bh = reg["blocked_hosts"]
    existing = None
    for e in bh:
        if isinstance(e, dict) and e.get("host", "").lower() == hostname.lower():
            existing = e
            break
    if existing:
        existing["failure_count"] = existing.get("failure_count", 0) + 1
        existing["last_failure"] = now_utc().isoformat()
        existing["last_error"] = error_code
        existing["last_niche"] = niche_id
        if existing["failure_count"] >= 3:
            existing["blocked"] = True
            existing["blocked_at"] = now_utc().isoformat()
    else:
        bh.append({"host": hostname.lower(), "failure_count": 1,
                   "first_failure": now_utc().isoformat(),
                   "last_failure": now_utc().isoformat(),
                   "last_error": error_code, "last_niche": niche_id, "blocked": False})
    try:
        write_yaml_atomic(reg, rp)
    except ValueError as e:
        emit_log("ERROR", f"Failed to write DEAD_HOST_REGISTRY: {e}")


def ping_dataforseo() -> dict:
    """Check DataForSEO API connectivity (WARNING on fail, not BLOCKED)."""
    import os as _os, requests as _req
    l, p = _os.environ.get("DATAFORSEO_LOGIN"), _os.environ.get("DATAFORSEO_PASSWORD")
    if not l or not p:
        return {"dataforseo_check": "SKIPPED", "dataforseo_warnings": ["Creds not set."]}
    try:
        r = _req.post("https://api.dataforseo.com/v3/serp/google/organic/live/advanced",
                       auth=(l, p), timeout=(5, 30),
                       json=[{"keyword": "sanity check", "language_code": "en", "location_code": 2840}])
        if r.status_code == 200:
            bal = r.json().get("summary", {}).get("balance")
            return {"dataforseo_check": "PASS", "dataforseo_balance": bal}
        elif r.status_code == 402:
            return {"dataforseo_check": "WARNING", "dataforseo_balance": 0.0,
                    "dataforseo_warnings": ["Balance EXHAUSTED (HTTP 402)."]}
        return {"dataforseo_check": "WARNING",
                "dataforseo_warnings": [f"HTTP {r.status_code}."]}
    except _req.exceptions.Timeout:
        return {"dataforseo_check": "WARNING", "dataforseo_warnings": ["Timed out."]}
    except _req.exceptions.ConnectionError as e:
        return {"dataforseo_check": "WARNING", "dataforseo_warnings": [f"Unreachable: {e}"]}


def check_firecrawl_credit_usage() -> dict:
    """Run firecrawl credit-usage for API-reported balance (SRE-L05)."""
    import subprocess as _sp, json as _json
    try:
        r = _sp.run(["firecrawl", "credit-usage"], capture_output=True, text=True, timeout=15)
        if r.returncode != 0:
            return {"credit_usage_check": "WARNING", "api_balance": None,
                    "credit_usage_warnings": ["Command failed."]}
        bal = "unknown"
        out = r.stdout.strip()
        if out:
            try:
                parsed = _json.loads(out)
                bal = parsed.get("remaining", parsed.get("credits", "unknown"))
            except (_json.JSONDecodeError, AttributeError):
                for line in out.splitlines():
                    if "remaining" in line.lower():
                        for p in line.split():
                            try:
                                bal = int(p)
                                break
                            except ValueError:
                                continue
        return {"credit_usage_check": "PASS" if bal != "unknown" else "WARNING", "api_balance": bal}
    except FileNotFoundError:
        return {"credit_usage_check": "WARNING", "api_balance": None,
                "credit_usage_warnings": ["CLI not found."]}
    except _sp.TimeoutExpired:
        return {"credit_usage_check": "WARNING", "api_balance": None,
                "credit_usage_warnings": ["Timed out."]}


def check_dataforseo_balance() -> dict:
    """Per-call DFS balance check (SRE-HB2)."""
    import os as _os, requests as _req
    l, p = _os.environ.get("DATAFORSEO_LOGIN"), _os.environ.get("DATAFORSEO_PASSWORD")
    if not l or not p:
        return {"dfs_balance_check": "SKIPPED", "dfs_balance": None}
    try:
        r = _req.get("https://api.dataforseo.com/v3/dataforseo/account",
                     auth=(l, p), timeout=(5, 15))
        if r.status_code == 200:
            bal = r.json().get("summary", {}).get("balance", 0.0)
            if bal <= 0:
                return {"dfs_balance_check": "BLOCKED", "dfs_balance": bal,
                        "dfs_balance_warnings": ["Balance /bin/bash. Top up."]}
            return {"dfs_balance_check": "PASS", "dfs_balance": bal}
        elif r.status_code == 402:
            return {"dfs_balance_check": "BLOCKED", "dfs_balance": 0.0,
                    "dfs_balance_warnings": ["Balance exhausted (402)."]}
        return {"dfs_balance_check": "WARNING", "dfs_balance": None,
                "dfs_balance_warnings": [f"HTTP {r.status_code}."]}
    except _req.exceptions.RequestException as e:
        return {"dfs_balance_check": "WARNING", "dfs_balance": None,
                "dfs_balance_warnings": [f"Failed: {e}"]}


def self_check() -> None:
    """Run all GATE health checks via --self-check."""
    emit_log("INFO", "=" * 60)
    emit_log("INFO", "PREFLIGHT SELF-CHECK: Running all GATE health checks")
    emit_log("INFO", "=" * 60)
    results = {}
    max_s = 0
    checks = [
        ("python_deps", check_python_deps, "deps_check"),
        ("disk_space", check_disk_space, "disk_check"),
        ("firecrawl_health", ping_firecrawl, "firecrawl_check"),
        ("dataforseo_health", ping_dataforseo, "dataforseo_check"),
        ("mcp_servers", ping_mcp_servers, "mcp_check"),
        ("concurrency_lock", check_concurrency_lock, "concurrency_lock_check"),
        ("mcp_schedule", check_mcp_schedule, "mcp_schedule_check"),
        ("firecrawl_credits", check_firecrawl_credit_usage, "credit_usage_check"),
        ("dataforseo_balance", check_dataforseo_balance, "dfs_balance_check"),
    ]
    for name, fn, key in checks:
        emit_log("INFO", f"[Check] {name}...")
        r = fn()
        results[name] = r
        s = r.get(key, "UNKNOWN")
        if s == "BLOCKED":
            max_s = max(max_s, 1)
        elif s == "WARNING":
            max_s = max(max_s, 2)
    if max_s >= 1:
        ec, vl = ExitCode.BLOCKED, "BLOCKED"
    elif max_s == 2:
        ec, vl = ExitCode.WARNING, "WARNING"
    else:
        ec, vl = ExitCode.SUCCESS, "PASS"
    emit_log("INFO", "=" * 60)
    emit_log("INFO", f"SELF-CHECK VERDICT: {vl} (exit {ec.value})")
    emit_log("INFO", "=" * 60)
    emit_result(ec, {"verdict": f"SELF_CHECK_{vl}", "self_check": results})


def main() -> None:
    """Entry point. Parse args, run checks, emit verdict."""
    args = sys.argv[1:]

    # ── Handle --help ──────────────────────────────────────────────────────
    if "--help" in args or "-h" in args:
        print_help()
    # ── Handle --self-check ───────────────────────────────────────────
    if "--self-check" in args:
        self_check()

    # ── Extract --force ────────────────────────────────────────────────────
    force_flag = "--force" in args
    if force_flag:
        args.remove("--force")

    # ── Extract --dry-run ──────────────────────────────────────────────────
    dry_run = "--dry-run" in args
    if dry_run:
        args.remove("--dry-run")

    # ── Extract --quiet / --agent-mode ─────────────────────────────────────
    quiet_mode = "--quiet" in args
    if quiet_mode:
        args.remove("--quiet")
    agent_mode = "--agent-mode" in args
    if agent_mode:
        args.remove("--agent-mode")
    if agent_mode:
        set_agent_mode(True)
    elif quiet_mode:
        set_quiet_mode(True)

    # ── Extract --target-url ───────────────────────────────────────────────
    target_url, remaining = _extract_target_url(args)
    args = remaining

    # Handle --target-url "" (flag provided without a value)
    if target_url == "":
        emit_log("WARNING",
                 "--target-url flag provided but no URL value given."
                 " Skipping URL-dependent checks.")
        target_url = None

    # ── Parse positional arguments ─────────────────────────────────────────
    if len(args) < 2:
        emit_log("ERROR",
                 f"Usage: {SCRIPT_NAME} NICHE_ID DATA_TYPE"
                 " [--target-url URL] [--force] [--dry-run]")
        emit_result(ExitCode.INVALID_INPUT, {
            "error":
                f"Expected at least 2 positional arguments, got {len(args)}.",
            "usage":
                f"{SCRIPT_NAME} NICHE_ID DATA_TYPE"
                " [--target-url URL] [--force] [--dry-run]",
        })

    niche_id = args[0]
    data_type = args[1]

    # ==========================================================================
    # Step 1: Input Validation
    # ==========================================================================
    validate_inputs(niche_id, data_type, target_url)

    # ==========================================================================
    # Step 1b: Governance File Checks (SRE-C07, SRE-M05)
    # ==========================================================================
    concurrency_result = check_concurrency_lock()
    mcp_result = check_mcp_schedule()

    # ==========================================================================
    # Step 2: Cache Check
    # ==========================================================================
    cache_result = check_cache(niche_id, data_type, target_url, dry_run)
    cache_status = cache_result["cache_status"]
    cache_verdict = cache_result.get("verdict", "PROCEED")

    # Cache HIT -> early exit with SKIP_CACHE_HIT (exit 0)
    if cache_verdict == "SKIP_CACHE_HIT":
        emit_log("INFO",
                 "VERDICT: SKIP_CACHE_HIT -- fresh data cached."
                 " No fetch needed.")
        result_data = {
            "verdict": "SKIP_CACHE_HIT",
            "cache_status": "HIT",
            "credit_check": "SKIPPED",
            "dead_host_check": "SKIPPED",
            "concurrency_check": concurrency_result["concurrency_lock_check"],
            "mcp_schedule_check": mcp_result["mcp_schedule_check"],
            "niche_id": niche_id,
            "data_type": data_type,
            "estimated_credits":
                ESTIMATED_COSTS.get(data_type, {}).get("firecrawl", DEFAULT_ESTIMATED_CREDITS),
            "credits_remaining": 0,
        }
        emit_result(ExitCode.SUCCESS, result_data)

    # ==========================================================================
    # Step 3: Credit Balance Check
    # ==========================================================================
    credit_result = check_credits(data_type)

    # Credits BLOCKED -> early exit (exit 1), unless --force
    if credit_result.get("credit_check") == "BLOCKED" and not force_flag:
        for w in credit_result.get("credit_warnings", []):
            emit_log("WARNING", w)
        emit_log("ERROR",
                 "VERDICT: BLOCKED_CREDITS --"
                 f" {credit_result.get('blocked_reason', 'Insufficient credits')}")
        result_data = {
            "verdict": "BLOCKED_CREDITS",
            "cache_status": cache_status,
            "credit_check": "BLOCKED",
            "dead_host_check": "SKIPPED",
            "concurrency_check": concurrency_result["concurrency_lock_check"],
            "mcp_schedule_check": mcp_result["mcp_schedule_check"],
            "niche_id": niche_id,
            "data_type": data_type,
            "estimated_credits": credit_result["estimated_credits"],
            "credits_remaining": credit_result["credits_remaining"],
            "blocked_reason":
                credit_result.get("blocked_reason", "Insufficient credits"),
            "resolution_hint":
                "Top up firecrawl credits (see CREDIT_BUDGET.yaml)"
                " or choose a lower-cost data type.",
        }
        emit_result(ExitCode.BLOCKED, result_data)
    elif credit_result.get("credit_check") == "BLOCKED" and force_flag:
        # --force: downgrade BLOCKED to WARNING
        emit_log("WARNING",
                 "CREDITS BLOCKED but --force set. Proceeding with WARNING.")
        credit_result["credit_check"] = "WARNING"

    # ==========================================================================
    # Step 4: Dead-Host Registry Check
    # ==========================================================================
    dead_host_result = check_dead_host(target_url)

    # Dead host BLOCKED -> early exit (exit 1), unless --force
    if dead_host_result.get("dead_host_check") == "BLOCKED" and not force_flag:
        emit_log("ERROR",
                 "VERDICT: BLOCKED_DEAD_HOST --"
                 f" {dead_host_result.get('dead_host_note', 'Target host is dead')}")
        result_data = {
            "verdict": "BLOCKED_DEAD_HOST",
            "cache_status": cache_status,
            "credit_check": credit_result.get("credit_check", "UNKNOWN"),
            "dead_host_check": "BLOCKED",
            "concurrency_check": concurrency_result["concurrency_lock_check"],
            "mcp_schedule_check": mcp_result["mcp_schedule_check"],
            "niche_id": niche_id,
            "data_type": data_type,
            "estimated_credits": credit_result["estimated_credits"],
            "credits_remaining": credit_result["credits_remaining"],
            "blocked_reason":
                dead_host_result.get("dead_host_note", "Target host is dead"),
            "resolution_hint":
                "Check if the host is back online and remove"
                " from DEAD_HOST_REGISTRY.yaml.",
        }
        emit_result(ExitCode.BLOCKED, result_data)
    elif dead_host_result.get("dead_host_check") == "BLOCKED" and force_flag:
        # --force: downgrade BLOCKED to WARNING
        emit_log("WARNING",
                 "DEAD HOST BLOCKED but --force set. Proceeding with WARNING.")
        dead_host_result["dead_host_check"] = "WARNING"

    # ==========================================================================
    # Step 5: Verdict Assembly
    # ==========================================================================

    # Collect any warning-level flags
    warnings: list[str] = []
    if credit_result.get("credit_check") == "WARNING":
        warnings.extend(credit_result.get("credit_warnings", []))
    if dead_host_result.get("dead_host_check") == "WARNING":
        dh_note = dead_host_result.get("dead_host_note", "")
        if dh_note:
            warnings.append(dh_note)
    # Concurrency lock and MCP schedule are logged but do NOT change exit code
    # in the main fetch flow (they are governance checks, not pipeline checks).
    # Use --self-check for a comprehensive system health audit.
    if concurrency_result.get("concurrency_lock_check") == "WARNING":
        emit_log("INFO", f"  Concurrency lock: {concurrency_result['concurrency_lock_check']} (not blocking)")
    if mcp_result.get("mcp_schedule_check") == "WARNING":
        emit_log("INFO", f"  MCP schedule: {mcp_result['mcp_schedule_check']} (not blocking)")

    if force_flag:
        warnings.append("--force flag active: blocking checks overridden")

    if warnings:
        exit_code = ExitCode.WARNING
        emit_log("WARNING", "VERDICT: PROCEED (with warnings)")
        for w in warnings:
            emit_log("WARNING", f"  - {w}")
    else:
        exit_code = ExitCode.SUCCESS
        emit_log("INFO", "VERDICT: PROCEED -- all checks passed.")

    # Summary logs to stderr
    if cache_status in ("STALE", "MISS"):
        emit_log("INFO",
                 f"  Cache: {cache_status}"
                 f" ({cache_result.get('reason', '')})")
    emit_log("INFO",
             f"  Credits: {credit_result.get('credit_check', 'UNKNOWN')}"
             f" ({credit_result['credits_remaining']} remaining,"
             f" {credit_result['estimated_credits']} estimated)")
    dh_status = dead_host_result.get("dead_host_check", "SKIPPED")
    dh_note = dead_host_result.get("dead_host_note", "")
    emit_log("INFO",
             f"  Dead-host: {dh_status}"
             + (f" ({dh_note})" if dh_note else ""))
    conc_status = concurrency_result.get("concurrency_lock_check", "SKIPPED")
    emit_log("INFO",
             f"  Concurrency lock: {conc_status}")
    mcp_status = mcp_result.get("mcp_schedule_check", "SKIPPED")
    emit_log("INFO",
             f"  MCP schedule: {mcp_status}")

    # Build result JSON
    result_data = {
        "verdict": "PROCEED",
        "cache_status": cache_status,
        "credit_check": credit_result.get("credit_check", "UNKNOWN"),
        "dead_host_check": dead_host_result.get("dead_host_check", "SKIPPED"),
        "concurrency_check": concurrency_result["concurrency_lock_check"],
        "mcp_schedule_check": mcp_result["mcp_schedule_check"],
        "niche_id": niche_id,
        "data_type": data_type,
        "estimated_credits": credit_result["estimated_credits"],
        "credits_remaining": credit_result["credits_remaining"],
    }

    if force_flag:
        result_data["force_used"] = True

    if warnings:
        result_data["warnings"] = warnings

    if dry_run:
        result_data["cache_details"] = cache_result
        result_data["credit_details"] = credit_result
        result_data["dead_host_details"] = dead_host_result
        result_data["concurrency_details"] = concurrency_result
        result_data["mcp_schedule_details"] = mcp_result
        emit_log("INFO",
                 "DRY RUN: No state was mutated. Above is what would happen.")

    emit_result(exit_code, result_data)


if __name__ == "__main__":
    main()
