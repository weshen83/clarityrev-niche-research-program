def _extract_target_url(args: list) -> tuple:
    """
    Extract --target-url VALUE from argument list.

    Returns (target_url_value, remaining_args).
    target_url_value is None if flag not present, "" if flag present without value.
    """
    remaining = []
    value = None
    skip_next = False
    for i, arg in enumerate(args):
        if skip_next:
            skip_next = False
            continue
        if arg == "--target-url":
            if i + 1 < len(args) and not args[i + 1].startswith("--"):
                value = args[i + 1]
                skip_next = True
            else:
                value = ""  # Flag present but no value
        else:
            remaining.append(arg)
    return value, remaining


