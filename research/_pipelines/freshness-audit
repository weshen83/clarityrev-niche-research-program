def validate_trace_map(data: Any) -> List[Dict[str, Any]]:
    """
    Validate trace-map.yaml structure per §4.2 Step 1.

    Required structure:
      - Top-level 'claims' key that is a list
      - Each claim must have: claim_id, sources (list)
      - Each source must have: source_file, fetch_date, freshness_status, fresh_until

    Returns the list of claims on success.
    Raises ValueError with detailed error message on schema violation.
    """
    if not isinstance(data, dict):
        raise ValueError(
            "trace-map.yaml root must be a dictionary with a 'claims' key"
        )

    if "claims" not in data:
        raise ValueError(
            "trace-map.yaml missing required top-level key: 'claims'"
        )

    claims = data["claims"]
    if not isinstance(claims, list):
        raise ValueError(
            "trace-map.yaml 'claims' must be a list, "
            f"got {type(claims).__name__}"
        )

    if len(claims) == 0:
        raise ValueError("trace-map.yaml 'claims' list is empty")

    errors: List[str] = []
    for i, claim in enumerate(claims):
        if not isinstance(claim, dict):
            errors.append(f"claims[{i}]: expected dict, got {type(claim).__name__}")
            continue

        if "claim_id" not in claim:
            errors.append(f"claims[{i}]: missing required field 'claim_id'")

        if "sources" not in claim:
            errors.append(f"claims[{i}]: missing required field 'sources'")
        elif not isinstance(claim["sources"], list):
            errors.append(
                f"claims[{i}].sources: expected list, "
                f"got {type(claim['sources']).__name__}"
            )
        else:
            for j, src in enumerate(claim["sources"]):
                if not isinstance(src, dict):
                    errors.append(f"claims[{i}].sources[{j}]: expected dict")
                    continue
                for field in ("source_file", "fetch_date", "freshness_status", "fresh_until"):
                    if field not in src:
                        errors.append(
                            f"claims[{i}].sources[{j}]: missing required field '{field}'"
                        )

    if errors:
        raise ValueError("trace-map.yaml schema violation: " + "; ".join(errors))

    return claims


