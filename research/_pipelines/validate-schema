def parse_validate_args():
    """
    Parse command-line arguments for validate-schema (single-file mode).
    Returns (data_type, file_path, schema_dir, dry_run).
    """
    args = sys.argv[1:]

    if not args or "--help" in args or "-h" in args:
        print_help()

    dry_run = "--dry-run" in args
    if dry_run:
        args.remove("--dry-run")

    schema_dir = None
    if "--schema-dir" in args:
        idx = args.index("--schema-dir")
        if idx + 1 < len(args) and not args[idx + 1].startswith("--"):
            schema_dir = Path(args[idx + 1]).resolve()
            args = args[:idx] + args[idx+2:]
        else:
            emit_log("ERROR", "--schema-dir requires a path argument")
            emit_result(ExitCode.INVALID_INPUT, {
                "error": "--schema-dir requires a path argument",
            })

    if len(args) < 2:
        emit_log("ERROR", "Missing required positional arguments")
        emit_result(ExitCode.INVALID_INPUT, {
            "error": "Missing required positional arguments: DATA_TYPE FILE_PATH",
            "valid_data_types": sorted(VALID_DATA_TYPES)
        })

    data_type = args[0]
    file_path_arg = args[1]

    if data_type not in VALID_DATA_TYPES:
        emit_log("ERROR", "Unknown DATA_TYPE: '%s'" % data_type)
        emit_result(ExitCode.INVALID_INPUT, {
            "error": "Unknown DATA_TYPE: '%s'" % data_type,
            "valid_data_types": sorted(VALID_DATA_TYPES)
        })

    data_file = Path(file_path_arg).resolve()
    # Reject paths outside project directory
    try:
        data_file.relative_to(PROGRAM_ROOT)
    except ValueError:
        emit_log("ERROR", "File path is outside project directory: %s" % data_file)
        emit_result(ExitCode.INVALID_INPUT, {
            "error": "File path is outside project directory: %s" % str(data_file),
            "file_path": repo_relative_path(data_file),
            "program_root": str(PROGRAM_ROOT)
        })
    if not data_file.exists():
        emit_log("ERROR", "File not found: %s" % data_file)
        emit_result(ExitCode.INVALID_INPUT, {
            "error": "File not found: %s" % str(data_file),
            "file_path": repo_relative_path(data_file)
        })

    if not data_file.is_file():
        emit_log("ERROR", "Path is not a file: %s" % data_file)
        emit_result(ExitCode.INVALID_INPUT, {
            "error": "Path is not a file: %s" % str(data_file)
        })

    return data_type, data_file, schema_dir, dry_run


