def get_niche_directories():
    """Return sorted list of non-system niche directories under research/."""
    from lib.pipeline_ops import _RESEARCH_DIR
    research_dir = _RESEARCH_DIR
    niches = []
    for entry in sorted(research_dir.iterdir()):
        if entry.is_dir() and re.match(r"^(N-\d{3}|CAL-[AB])$", entry.name):
            niches.append(entry)
    return niches


def scan_and_validate(target_niches, schemas_dir, verbose):
    """
    Scan and validate all niches in target_niches.

    Args:
        target_niches: list of Paths to niche directories
        schemas_dir: Path to schema directory
        verbose: bool for detailed error output

    Returns (overall_exit_code, aggregated_results).
    """
    overall_exit_code = ExitCode.SUCCESS
    all_results = []
    total_passed = 0
    total_failed = 0
    total_warnings = 0
    files_checked = 0

    for niche_dir in target_niches:
        niche_id = niche_dir.name
        emit_log("INFO", f"Scanning niche: {niche_id} ({niche_dir})")

        # --- Validate trace-map.yaml ---
        trace_map_path = niche_dir / "_canvas" / "evidence" / "trace-map.yaml"
        if trace_map_path.exists():
            tc_exit, tc_result = validate_trace_map_structure(trace_map_path)
            tc_result["niche_id"] = niche_id
            tc_result["file_type"] = "trace-map.yaml"
            all_results.append(tc_result)
            files_checked += 1
            if tc_exit.value > 0:
                if tc_exit.value > overall_exit_code.value:
                    overall_exit_code = tc_exit
                total_failed += 1
                emit_log("WARNING" if tc_exit.value < 2 else "ERROR",
                         f"  trace-map.yaml: {tc_result['verdict']} ({tc_result.get('violations', '?')} violations)")
            else:
                total_passed += 1
                emit_log("INFO", f"  trace-map.yaml: PASS")
        else:
            emit_log("INFO", f"  trace-map.yaml not found (not yet authored)")
            total_warnings += 1

        # --- Validate evidence-claims.json ---
        claims_json_path = niche_dir / "_canvas" / "evidence" / "evidence-claims.json"
        if claims_json_path.exists():
            cj_exit, cj_result = validate_evidence_claims(claims_json_path)
            cj_result["niche_id"] = niche_id
            cj_result["file_type"] = "evidence-claims.json"
            all_results.append(cj_result)
            files_checked += 1
            if cj_exit.value > 0:
                if cj_exit.value > overall_exit_code.value:
                    overall_exit_code = cj_exit
                total_failed += 1
            else:
                total_passed += 1

        # --- Validate all YAML files in niche ---
        yaml_files = []
        for entry in sorted(niche_dir.rglob("*.yaml")):
            # Skip tmp files
            if entry.suffix == ".tmp":
                continue
            # Skip hidden/temp
            if entry.name.startswith("."):
                continue
            # Skip directories starting with SKIP_DIR_PREFIXES
            rel = entry.relative_to(niche_dir)
            skip = False
            for part in rel.parts:
                if part.startswith("_") or part in SKIP_DIR_PREFIXES:
                    skip = True
                    break
            # But DO validate trace-map.yaml (already handled above)
            if "trace-map" in entry.name:
                continue
            if skip:
                continue
            yaml_files.append(entry)

        for yf in yaml_files:
            data_type = infer_data_type_from_path(yf, niche_dir)
            if data_type is None:
                emit_log("INFO", f"  SKIP {repo_relative_path(yf)} (no matching schema)")
                all_results.append({
                    "file": repo_relative_path(yf),
                    "niche_id": niche_id,
                    "verdict": "SKIPPED",
                    "reason": "No matching schema found for this file",
                    "file_type": "yaml",
                })
                continue

            f_exit, f_result = validate_single_file(yf, data_type, schemas_dir, verbose)
            f_result["niche_id"] = niche_id
            f_result["file_type"] = "yaml"
            all_results.append(f_result)
            files_checked += 1

            status = "PASS" if f_exit == ExitCode.SUCCESS else (
                "PASS_WITH_WARNINGS" if f_exit == ExitCode.WARNING else "FAIL")
            if f_exit.value > 0:
                if f_exit.value > overall_exit_code.value:
                    overall_exit_code = f_exit
                if f_exit == ExitCode.WARNING:
                    total_warnings += 1
                else:
                    total_failed += 1
            else:
                total_passed += 1

            emit_log("INFO", f"  {yf.name}: {status}")

    emit_log("INFO", f"Batch validation complete: {total_passed} passed, "
                     f"{total_failed} failed, {total_warnings} warnings "
                     f"({files_checked} files)")

    aggregate = {
        "verdict": "FAIL" if total_failed > 0 else (
            "PASS_WITH_WARNINGS" if total_warnings > 0 else "PASS"),
        "mode": "all" if len(target_niches) > 1 else f"niche={target_niches[0].name}",
        "niches_scanned": len(target_niches),
        "total_files": files_checked,
        "passed": total_passed,
        "failed": total_failed,
        "warnings": total_warnings,
        "results": all_results,
    }

    if verbose:
        aggregate["niche_directories"] = [str(d) for d in target_niches]

    return overall_exit_code, aggregate


