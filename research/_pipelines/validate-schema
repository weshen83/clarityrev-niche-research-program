def infer_data_type_from_path(file_path: Path, niche_dir: Path):
    """
    Infer the schema data type for a YAML file based on its filename and
    directory location within the niche.

    Returns a data type string (key into DATA_TYPE_SCHEMA_MAP) or None
    if no schema could be inferred.
    """
    stem = file_path.stem  # e.g., N-001-competitor-pricing-syncgtm-v1

    # 1. Check for special files (trace-map.yaml, frontmatter)
    if stem == "trace-map":
        return None  # Handled separately by validate_trace_map()
    if stem.startswith("frontmatter-"):
        return "canvas-frontmatter"

    # 2. Check parent directory name
    try:
        rel = file_path.relative_to(niche_dir)
        parent_dir = rel.parent.name if rel.parent else ""
        if parent_dir in DIRECTORY_INFERENCE_MAP:
            return DIRECTORY_INFERENCE_MAP[parent_dir]
    except ValueError:
        pass

    # 3. Check for descriptive keywords in the stem (after stripping
    #    niche_id prefix like N-001- or CAL-A-)
    desc_part = stem
    parts = stem.split("-", 2)
    if len(parts) >= 3 and re.match(r"^(N-\d{3}|CAL-[AB])$", parts[0] + "-" + parts[1][:0]):
        desc_part = parts[1] + "-" + parts[2]
    elif len(parts) >= 2 and re.match(r"^(N-\d{3}|CAL-[AB])$", parts[0]):
        desc_part = parts[1] if len(parts) > 1 else ""

    for keyword, data_type in FILENAME_INFERENCE_MAP.items():
        if keyword in desc_part.lower():
            return data_type

    # 4. Check any keyword in full stem
    for keyword, data_type in FILENAME_INFERENCE_MAP.items():
        if keyword in stem.lower():
            return data_type

    return None


