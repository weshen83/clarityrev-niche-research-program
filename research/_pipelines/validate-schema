def load_and_validate_schema(data_type, schema_dir=None):
    """
    Load the schema definition file for the given data type.

    Returns:
        (schema_data: dict, schema_path: Path)
    """
    if schema_dir is None:
        schema_dir = SCHEMAS_DIR

    schema_filename = DATA_TYPE_SCHEMA_MAP[data_type]
    schema_path = schema_dir / schema_filename

    if not schema_path.exists():
        emit_log("ERROR", "Schema file not found: %s" % schema_path)
        emit_result(ExitCode.INTERNAL_ERROR, {
            "error": "Schema file not found: %s" % str(schema_path),
            "schema_file": repo_relative_path(schema_path)
        })

    try:
        schema_data = load_yaml_safe(schema_path)
    except ValueError as e:
        emit_log("ERROR", "Schema file corrupted: %s — %s" % (schema_path, e))
        emit_result(ExitCode.INTERNAL_ERROR, {
            "error": "Schema file corrupted: %s" % str(schema_path),
            "details": str(e),
            "schema_file": repo_relative_path(schema_path),
        })
    if schema_data is None:
        emit_log("ERROR", "Failed to load schema (empty or missing): %s" % schema_path)
        emit_result(ExitCode.INTERNAL_ERROR, {
            "error": "Failed to load schema: %s" % str(schema_path),
            "schema_file": repo_relative_path(schema_path)
        })

    _validate_schema_structure(schema_data, schema_path)

    schema_meta = schema_data.get("schema", {})
    emit_log("INFO", "Loaded schema: %s v%s" % (
        schema_meta.get("name", schema_filename),
        schema_meta.get("version", "?")
    ))

    return schema_data, schema_path


def _validate_schema_structure(schema_data, schema_path):
    """Validate that the loaded schema has the required structure."""

    if not isinstance(schema_data, dict):
        raise ValueError("Schema at %s must be a mapping (dict), got %s" % (
            schema_path, type(schema_data).__name__))

    if "schema" not in schema_data:
        raise ValueError("Schema at %s missing required top-level key 'schema'" % schema_path)

    schema_meta = schema_data["schema"]
    if not isinstance(schema_meta, dict):
        raise ValueError("Schema at %s.schema must be a mapping, got %s" % (
            schema_path, type(schema_meta).__name__))

    for key in ("name", "version", "source"):
        if key not in schema_meta:
            raise ValueError("Schema at %s missing schema.%s" % (schema_path, key))

    if "fields" not in schema_data or not isinstance(schema_data["fields"], list):
        raise ValueError("Schema at %s missing or invalid 'fields' list" % schema_path)

    for i, field in enumerate(schema_data["fields"]):
        if not isinstance(field, dict):
            raise ValueError("Schema at %s field[%d] must be a mapping, got %s" % (
                schema_path, i, type(field).__name__))
        for key in ("field", "type", "required"):
            if key not in field:
                raise ValueError("Schema at %s field[%d] ('%s') missing required key '%s'" % (
                    schema_path, i, field.get("field", "?"), key))

    return True


# ============================================================================
# TYPE CHECKING
# ============================================================================

_STRING_SUBTYPES = frozenset({
    "string (url)", "string (iso 8601 date)", "string (duration)",
    "string (path)",
})


def _check_value_type(value, type_str):
    """
    Check that value matches the expected type_str.

    Supports: string, string (URL), string (ISO 8601 date), string (duration),
    string (path), integer, number, float, boolean, list, array, object, dict,
    array of strings, array of <type>.

    Returns True if the value matches the type, False otherwise.
    """
    if type_str is None:
        return True

    type_lower = type_str.lower().strip()

    if type_lower.startswith("array of "):
        item_type = type_lower[9:].strip()
        if not isinstance(value, list):
            return False
        return all(_check_value_type(v, item_type) for v in value)

    if type_lower in _STRING_SUBTYPES:
        return isinstance(value, str)
    elif type_lower == "string":
        return isinstance(value, str)
    elif type_lower == "integer":
        return isinstance(value, int) and not isinstance(value, bool)
    elif type_lower in ("number", "float"):
        return isinstance(value, (int, float)) and not isinstance(value, bool)
    elif type_lower == "boolean":
        return isinstance(value, bool)
    elif type_lower in ("list", "array"):
        return isinstance(value, list)
    elif type_lower in ("dict", "object"):
        return isinstance(value, dict)

    return True


def _validate_string_format(value, type_str):
    """
    Validate string subtype format.

    Returns (is_valid: bool, error_message: Optional[str])
    """
    type_lower = type_str.lower().strip()

    if type_lower == "string (iso 8601 date)":
        if not isinstance(value, str):
            return False, "Not a string"
        if re.match(r"^\d{4}-\d{2}-\d{2}$", value):
            return True, None
        try:
            datetime.fromisoformat(value)
            return True, None
        except ValueError:
            return False, "'%s' is not a valid ISO 8601 date (expected YYYY-MM-DD)" % value

    elif type_lower == "string (url)":
        if not isinstance(value, str):
            return False, "Not a string"
        parsed = urlparse(value)
        if parsed.scheme in ("http", "https") and bool(parsed.netloc):
            return True, None
        return False, "'%s' is not a valid URL (expected http/https scheme)" % value

    elif type_lower == "string (duration)":
        if not isinstance(value, str):
            return False, "Not a string"
        if re.match(r"^\d+d$", value):
            return True, None
        return False, "'%s' is not a valid duration (expected format like '90d')" % value

    elif type_lower == "string (path)":
        return isinstance(value, str), None

    return True, None


# ============================================================================
# RECURSIVE FIELD-BY-FIELD VALIDATION
# ============================================================================

def validate_recursive(data, schema_fields, path_prefix="",
                       violations=None, warnings=None,
                       required_present=None, optional_missing=None):
    """
    Recursively validate data against a list of schema field definitions.

    Supports:
    - Leaf fields: required, type, enum, range, string format checks
    - Object fields (with 'fields'/'children'): recurse into nested dict
    - Array fields (with 'items'/'item_schema'): recurse into each item
    """
    if violations is None:
        violations = []
    if warnings is None:
        warnings = []
    if required_present is None:
        required_present = []
    if optional_missing is None:
        optional_missing = []

    if not isinstance(data, dict):
        return

    for field_spec in schema_fields:
        field_name = field_spec.get("field")
        if not field_name:
            continue

        full_path = "%s.%s" % (path_prefix, field_name) if path_prefix else field_name
        value = data.get(field_name)

        required = field_spec.get("required", False)
        type_str = field_spec.get("type", "")
        enum_values = field_spec.get("enum")
        min_val = field_spec.get("min")
        max_val = field_spec.get("max")
        min_items = field_spec.get("min_items")

        children = field_spec.get("fields") or field_spec.get("children")
        item_schema = field_spec.get("items") or field_spec.get("item_schema")

        # -- 1. REQUIRED check --
        if required and (value is None or (isinstance(value, str) and value.strip() == "")):
            violations.append({
                "field": field_name,
                "path": full_path,
                "violation_type": "REQUIRED_MISSING",
                "expected": type_str,
                "actual": "None" if value is None else "empty string",
                "message": "Required field '%s' is missing or empty" % full_path
            })
            continue

        if required and value is not None:
            required_present.append(full_path)

        if not required and (value is None or (isinstance(value, str) and value.strip() == "")):
            optional_missing.append(full_path)
            continue

        # -- 2. TYPE check --
        type_ok = _check_value_type(value, type_str)
        if not type_ok:
            violations.append({
                "field": field_name,
                "path": full_path,
                "violation_type": "TYPE_MISMATCH",
                "expected": type_str,
                "actual": type(value).__name__,
                "message": "Field '%s' expected type '%s' but got %s" % (
                    full_path, type_str, type(value).__name__)
            })
            continue

        # -- 3. String FORMAT check --
        if (isinstance(value, str) and "string" in type_str.lower()
                and type_str.lower() != "string"):
            is_valid, err_msg = _validate_string_format(value, type_str)
            if not is_valid:
                violations.append({
                    "field": field_name,
                    "path": full_path,
                    "violation_type": "FORMAT_VIOLATION",
                    "expected": "valid %s format" % type_str,
                    "actual": value,
                    "message": err_msg or "Field '%s' does not match expected format for '%s'" % (
                        full_path, type_str)
                })

        # -- 4. ENUM check --
        if enum_values and value is not None and value not in enum_values:
            violations.append({
                "field": field_name,
                "path": full_path,
                "violation_type": "ENUM_VIOLATION",
                "expected": list(enum_values),
                "actual": str(value),
                "message": "Field '%s' value '%s' is not in allowed values: %s" % (
                    full_path, value, list(enum_values))
            })

        # -- 5. NUMERIC RANGE check --
        if isinstance(value, (int, float)) and not isinstance(value, bool):
            if min_val is not None and value < min_val:
                violations.append({
                    "field": field_name,
                    "path": full_path,
                    "violation_type": "RANGE_VIOLATION",
                    "expected": ">= %s" % min_val,
                    "actual": value,
                    "message": "Field '%s' value %s is below minimum %s" % (
                        full_path, value, min_val)
                })
            if max_val is not None and value > max_val:
                violations.append({
                    "field": field_name,
                    "path": full_path,
                    "violation_type": "RANGE_VIOLATION",
                    "expected": "<= %s" % max_val,
                    "actual": value,
                    "message": "Field '%s' value %s exceeds maximum %s" % (
                        full_path, value, max_val)
                })

        # -- 6. min_items check for array fields --
        if (isinstance(value, list) and min_items is not None
                and len(value) < min_items):
            warnings.append({
                "field": field_name,
                "path": full_path,
                "violation_type": "MIN_ITEMS",
                "expected": ">= %d items" % min_items,
                "actual": "%d items" % len(value),
                "message": "Field '%s' has %d items, minimum is %d" % (
                    full_path, len(value), min_items)
            })

        # -- 7. NESTED: recurse into object children --
        if children and isinstance(value, dict):
            validate_recursive(value, children, full_path,
                               violations, warnings,
                               required_present, optional_missing)

        # -- 8. NESTED: recurse into array items --
        elif item_schema and isinstance(value, list):
            _validate_array_items(value, item_schema, field_name, full_path,
                                  violations, warnings,
                                  required_present, optional_missing)


def _validate_array_items(items, item_schema, field_name, full_path,
                          violations, warnings,
                          required_present, optional_missing):
    """Validate each item in an array against the item schema."""

    items_type = item_schema.get("type", "").lower().strip()
    items_required = item_schema.get("required", [])
    item_fields = item_schema.get("fields") or item_schema.get("children") or []

    # Merge items.required list into individual field specs
    enhanced_fields = []
    for item_field in item_fields:
        enhanced = dict(item_field)
        fn = enhanced.get("field")
        if fn and fn in items_required:
            enhanced["required"] = True
        enhanced_fields.append(enhanced)

    for i, item in enumerate(items):
        item_path = "%s[%d]" % (full_path, i)

        if items_type in ("object", "dict") and not isinstance(item, dict):
            violations.append({
                "field": field_name,
                "path": item_path,
                "violation_type": "TYPE_MISMATCH",
                "expected": "object",
                "actual": type(item).__name__,
                "message": "Array item at '%s' expected object, got %s" % (
                    item_path, type(item).__name__)
            })
            continue

        if enhanced_fields and isinstance(item, dict):
            validate_recursive(item, enhanced_fields, item_path,
                               violations, warnings,
                               required_present, optional_missing)


