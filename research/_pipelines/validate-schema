def main():
    """
    Dispatch to batch mode (--all, --niche N-XXX) or single-file mode.
    """
    args = sys.argv[1:]

    # Global flags
    quiet_mode = "--quiet" in args
    if quiet_mode:
        args.remove("--quiet")
    agent_mode = "--agent-mode" in args
    if agent_mode:
        args.remove("--agent-mode")
    if agent_mode:
        set_agent_mode(True)
    elif quiet_mode:
        set_quiet_mode(True)

    verbose = "--verbose" in args
    if verbose:
        args.remove("--verbose")

    # Restore sys.argv for downstream parsing
    sys.argv = [sys.argv[0]] + args

    # Detect batch mode: --all or --niche N-XXX
    batch_all = "--all" in args
    batch_niche = None
    if "--niche" in args:
        nidx = args.index("--niche")
        if nidx + 1 < len(args) and not args[nidx + 1].startswith("--"):
            batch_niche = args[nidx + 1]
            args.remove(batch_niche)
        else:
            emit_log("ERROR", "--niche requires a niche ID argument (e.g., N-001)")
            emit_result(ExitCode.INVALID_INPUT, {
                "error": "--niche requires a niche ID argument",
                "usage": "./validate-schema --niche N-XXX",
            })
        args.remove("--niche")
    sys.argv = [sys.argv[0]] + args

    if batch_all or batch_niche:
        # ── Batch mode ─────────────────────────────────────────────────
        schemas_dir = SCHEMAS_DIR
        if "--schema-dir" in args:
            sdidx = args.index("--schema-dir")
            if sdidx + 1 < len(args) and not args[sdidx + 1].startswith("--"):
                schemas_dir = Path(args[sdidx + 1]).resolve()
        if not schemas_dir.exists():
            emit_result(ExitCode.INVALID_INPUT, {
                "error": "Schema directory not found",
                "schema_dir": str(schemas_dir),
            })

        # Resolve target niches
        import glob as glob_module
        if batch_all:
            target_niches = get_niche_directories()
            if not target_niches:
                emit_result(ExitCode.INVALID_INPUT, {
                    "error": "No niche directories found under research/",
                })
        else:
            from lib.pipeline_ops import _RESEARCH_DIR as _RES_DIR
            niche_dir = _RES_DIR / batch_niche
            if not niche_dir.is_dir():
                emit_result(ExitCode.INVALID_INPUT, {
                    "error": f"Niche directory not found: {niche_dir}",
                    "niche_id": batch_niche,
                })
            target_niches = [niche_dir]

        exit_code, results = scan_and_validate(target_niches, schemas_dir, verbose)
        emit_result(exit_code, results)

    else:
        # ── Single-file mode (backward compatible) ──────────────────────
        single_file_main()


if __name__ == "__main__":
    main()
