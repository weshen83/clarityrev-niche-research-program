def run_custom_validations(data_type, data, violations, warnings):
    """Run data-type-specific custom validation rules.

    Returns (custom_error_count, custom_warning_count)
    """
    dispatch = {
        "competitor-profile": _custom_cp,
        "review-corpus": _custom_rc,
        "market-sizing": _custom_ms,
        "canvas-frontmatter": _custom_cf,
    }
    fn = dispatch.get(data_type)
    if fn:
        return fn(data, violations, warnings)
    return 0, 0


# ---- Competitor Profile -----------------------------------------------------

def _custom_cp(data, violations, warnings):
    """Competitor-profile custom validation rules."""
    ec = wc = 0

    profile = data.get("profile", {})
    if not isinstance(profile, dict):
        violations.append({
            "field": "profile", "path": "profile",
            "violation_type": "CUSTOM_RULE",
            "expected": "object with competitor profile data",
            "actual": "type: %s" % type(profile).__name__,
            "message": "Competitor profile top-level 'profile' is missing or "
                       "not an object -- cannot check nested fields"
        })
        return 1, 0

    # fresh_until consistency with fetch_date + freshness_sla
    fd = data.get("fetch_date")
    fsla = data.get("freshness_sla")
    fu = data.get("fresh_until")
    if all(isinstance(v, str) for v in [fd, fsla, fu]):
        m = re.match(r"^(\d+)d$", fsla)
        if m:
            sla_days = int(m.group(1))
            try:
                fd_dt = datetime.strptime(fd[:10], "%Y-%m-%d")
                fu_dt = datetime.strptime(fu[:10], "%Y-%m-%d")
                exp = fd_dt + timedelta(days=sla_days)
                if abs((fu_dt - exp).days) > 1:
                    violations.append({
                        "field": "fresh_until", "path": "fresh_until",
                        "violation_type": "CUSTOM_RULE",
                        "expected": "~%s (= %s + %s)" % (
                            exp.strftime("%Y-%m-%d"), fd, fsla),
                        "actual": fu,
                        "message": "fresh_until '%s' inconsistent with "
                                   "fetch_date '%s' + freshness_sla '%s'" % (fu, fd, fsla)
                    })
                    ec += 1
            except (ValueError, TypeError):
                pass

    # pricing array: at least 1 entry (WARNING)
    pricing = profile.get("pricing", [])
    if isinstance(pricing, list) and len(pricing) == 0:
        warnings.append({
            "field": "pricing", "path": "profile.pricing",
            "violation_type": "CUSTOM_RULE",
            "expected": "at least 1 pricing tier",
            "actual": "empty pricing array",
            "message": "Pricing array is empty -- at least 1 entry recommended for DEEP depth"
        })
        wc += 1

    # strengths: at least 1 entry (ERROR)
    strengths = profile.get("strengths", [])
    if isinstance(strengths, list) and len(strengths) == 0:
        violations.append({
            "field": "strengths", "path": "profile.strengths",
            "violation_type": "CUSTOM_RULE",
            "expected": "at least 1 strength entry",
            "actual": "empty list",
            "message": "profile.strengths is empty -- at least 1 entry required"
        })
        ec += 1

    # weaknesses: at least 1 entry (ERROR)
    weaknesses = profile.get("weaknesses", [])
    if isinstance(weaknesses, list) and len(weaknesses) == 0:
        violations.append({
            "field": "weaknesses", "path": "profile.weaknesses",
            "violation_type": "CUSTOM_RULE",
            "expected": "at least 1 weakness entry",
            "actual": "empty list",
            "message": "profile.weaknesses is empty -- at least 1 entry required"
        })
        ec += 1

    # source_urls: at least 1 entry (ERROR)
    surls = data.get("source_urls", [])
    if isinstance(surls, list) and len(surls) == 0:
        violations.append({
            "field": "source_urls", "path": "source_urls",
            "violation_type": "CUSTOM_RULE",
            "expected": "at least 1 source URL",
            "actual": "empty list",
            "message": "source_urls is empty -- at least 1 source URL required"
        })
        ec += 1

    # vulnerabilities: at least 1 entry (ERROR)
    vulns = profile.get("vulnerabilities", [])
    if isinstance(vulns, list) and len(vulns) == 0:
        violations.append({
            "field": "vulnerabilities", "path": "profile.vulnerabilities",
            "violation_type": "CUSTOM_RULE",
            "expected": "at least 1 vulnerability entry",
            "actual": "empty list",
            "message": "profile.vulnerabilities is empty -- at least 1 entry required"
        })
        ec += 1

    # freshness_status consistency
    fstat = data.get("freshness_status")
    if isinstance(fstat, str) and isinstance(fu, str):
        try:
            fu_dt = datetime.strptime(fu[:10], "%Y-%m-%d")
            fu_aware = fu_dt.replace(tzinfo=timezone.utc)
            now = datetime.now(timezone.utc)
            exp_status = "FRESH" if now < fu_aware else "STALE"
            if fstat != exp_status:
                violations.append({
                    "field": "freshness_status", "path": "freshness_status",
                    "violation_type": "CUSTOM_RULE",
                    "expected": exp_status,
                    "actual": fstat,
                    "message": "freshness_status is '%s' but fresh_until '%s' "
                               "indicates '%s' (now: %s)" % (
                        fstat, fu, exp_status, now.strftime("%Y-%m-%d"))
                })
                ec += 1
        except (ValueError, TypeError):
            pass

    return ec, wc


# ---- Review Corpus -----------------------------------------------------------

def _custom_rc(data, violations, warnings):
    """Review-corpus custom validation rules."""
    ec = wc = 0

    # total_reviews must equal sum of source counts
    sources = data.get("sources", {})
    total = data.get("total_reviews")
    if isinstance(sources, dict) and isinstance(total, (int, float)):
        src_sum = 0
        for sk in ("g2", "capterra", "reddit"):
            s = sources.get(sk, {})
            if isinstance(s, dict):
                src_sum += s.get("count", 0) or 0
        if src_sum != total:
            violations.append({
                "field": "total_reviews", "path": "total_reviews",
                "violation_type": "CUSTOM_RULE",
                "expected": "sum of source counts (%d)" % src_sum,
                "actual": str(total),
                "message": "total_reviews (%s) does not equal sum of source counts (%d)" % (
                    total, src_sum)
            })
            ec += 1

    # Per-review checks: rating 1-5, unique review_id
    reviews = data.get("reviews", [])
    if isinstance(reviews, list):
        seen_ids = set()
        for i, rv in enumerate(reviews):
            if not isinstance(rv, dict):
                continue
            rating = rv.get("rating")
            if isinstance(rating, int) and not isinstance(rating, bool):
                if rating < 1 or rating > 5:
                    violations.append({
                        "field": "rating", "path": "reviews[%d].rating" % i,
                        "violation_type": "CUSTOM_RULE",
                        "expected": "integer between 1 and 5 inclusive",
                        "actual": str(rating),
                        "message": "Review #%d rating '%s' is outside allowed range (1-5)" % (
                            i + 1, rating)
                    })
                    ec += 1
            rid = rv.get("review_id")
            if rid and isinstance(rid, str):
                if rid in seen_ids:
                    violations.append({
                        "field": "review_id", "path": "reviews[%d].review_id" % i,
                        "violation_type": "CUSTOM_RULE",
                        "expected": "unique review_id",
                        "actual": rid,
                        "message": "Duplicate review_id '%s' at reviews[%d]" % (rid, i)
                    })
                    ec += 1
                seen_ids.add(rid)

        if len(reviews) == 0:
            violations.append({
                "field": "reviews", "path": "reviews",
                "violation_type": "CUSTOM_RULE",
                "expected": "at least 1 review entry",
                "actual": "empty reviews array",
                "message": "Review corpus has no review entries"
            })
            ec += 1

    # Warning: theme percentages should be 0-100
    ta = data.get("theme_analysis", {})
    if isinstance(ta, dict):
        for lk in ("top_praise_themes", "top_complaint_themes"):
            tl = ta.get(lk, [])
            if isinstance(tl, list):
                for j, entry in enumerate(tl):
                    if isinstance(entry, dict):
                        pct = entry.get("pct")
                        if isinstance(pct, (int, float)) and (pct < 0 or pct > 100):
                            warnings.append({
                                "field": "pct",
                                "path": "theme_analysis.%s[%d].pct" % (lk, j),
                                "violation_type": "CUSTOM_RULE",
                                "expected": "percentage 0-100",
                                "actual": str(pct),
                                "message": "Theme percentage '%s' is outside expected range 0-100" % pct
                            })
                            wc += 1

    return ec, wc


# ---- Market Sizing -----------------------------------------------------------

def _custom_ms(data, violations, warnings):
    """Market-sizing custom validation rules."""
    ec = wc = 0

    tam = data.get("tam", {})
    if not isinstance(tam, dict):
        violations.append({
            "field": "tam", "path": "tam",
            "violation_type": "CUSTOM_RULE",
            "expected": "object with TAM data",
            "actual": "type: %s" % type(tam).__name__,
            "message": "Top-level 'tam' is missing or not an object"
        })
        return 1, 0

    # revenue_eur must be non-negative
    rev = tam.get("revenue_eur")
    if isinstance(rev, (int, float)) and rev < 0:
        violations.append({
            "field": "revenue_eur", "path": "tam.revenue_eur",
            "violation_type": "CUSTOM_RULE",
            "expected": "non-negative integer",
            "actual": str(rev),
            "message": "TAM revenue_eur '%s' is negative" % rev
        })
        ec += 1

    # companies must be non-negative
    comp = tam.get("companies")
    if isinstance(comp, (int, float)) and comp < 0:
        violations.append({
            "field": "companies", "path": "tam.companies",
            "violation_type": "CUSTOM_RULE",
            "expected": "non-negative integer",
            "actual": str(comp),
            "message": "TAM companies '%s' is negative" % comp
        })
        ec += 1

    # tam.sources: at least 1 entry
    tsrc = tam.get("sources", [])
    if isinstance(tsrc, list) and len(tsrc) == 0:
        violations.append({
            "field": "sources", "path": "tam.sources",
            "violation_type": "CUSTOM_RULE",
            "expected": "at least 1 source entry",
            "actual": "empty list",
            "message": "tam.sources is empty -- at least 1 source required for [E] grade"
        })
        ec += 1

    # niche_existence_proof: at least 1 entry
    proofs = data.get("niche_existence_proof", [])
    if isinstance(proofs, list) and len(proofs) == 0:
        violations.append({
            "field": "niche_existence_proof", "path": "niche_existence_proof",
            "violation_type": "CUSTOM_RULE",
            "expected": "at least 1 evidence entry",
            "actual": "empty array",
            "message": "niche_existence_proof is empty -- at least 1 entry required"
        })
        ec += 1

    # WARNING: companies_range format
    cr = tam.get("companies_range")
    if isinstance(cr, str) and not re.match(r"^[0-9,]+-[0-9,]+$", cr):
        warnings.append({
            "field": "companies_range", "path": "tam.companies_range",
            "violation_type": "CUSTOM_RULE",
            "expected": "range pattern like '6,000-12,000'",
            "actual": cr,
            "message": "companies_range '%s' does not match expected pattern (e.g., '6,000-12,000')" % cr
        })
        wc += 1

    return ec, wc


# ---- Canvas Frontmatter ------------------------------------------------------

def _custom_cf(data, violations, warnings):
    """Canvas-frontmatter custom validation rules."""
    ec = wc = 0

    # composite_score 0-10 (ERROR)
    cs = data.get("composite_score")
    if isinstance(cs, (int, float)) and not isinstance(cs, bool):
        if cs < 0 or cs > 10:
            violations.append({
                "field": "composite_score", "path": "composite_score",
                "violation_type": "CUSTOM_RULE",
                "expected": "0.0 to 10.0 inclusive",
                "actual": str(cs),
                "message": "composite_score '%s' is outside range 0-10" % cs
            })
            ec += 1

    # composite_score_raw 0-10 (ERROR)
    csr = data.get("composite_score_raw")
    if isinstance(csr, (int, float)) and not isinstance(csr, bool):
        if csr < 0 or csr > 10:
            violations.append({
                "field": "composite_score_raw", "path": "composite_score_raw",
                "violation_type": "CUSTOM_RULE",
                "expected": "0.0 to 10.0 inclusive",
                "actual": str(csr),
                "message": "composite_score_raw '%s' is outside range 0-10" % csr
            })
            ec += 1

    # sub-scores 1-10 (ERROR)
    scores = data.get("scores", {})
    if isinstance(scores, dict):
        for sf in ("structural_attractiveness", "warm_access",
                    "commercial_viability", "build_feasibility"):
            val = scores.get(sf)
            if isinstance(val, int) and not isinstance(val, bool):
                if val < 1 or val > 10:
                    violations.append({
                        "field": sf, "path": "scores.%s" % sf,
                        "violation_type": "CUSTOM_RULE",
                        "expected": "integer between 1 and 10 inclusive",
                        "actual": str(val),
                        "message": "Sub-score '%s' value %s is outside range 1-10" % (sf, val)
                    })
                    ec += 1

    # evidence_quality 0-100 (ERROR)
    eq = data.get("evidence_quality")
    if isinstance(eq, (int, float)) and not isinstance(eq, bool):
        if eq < 0 or eq > 100:
            violations.append({
                "field": "evidence_quality", "path": "evidence_quality",
                "violation_type": "CUSTOM_RULE",
                "expected": "0.0 to 100.0 inclusive",
                "actual": str(eq),
                "message": "evidence_quality '%s' is outside range 0-100" % eq
            })
            ec += 1

    # freshness_score 0-100 (ERROR)
    fs = data.get("freshness_score")
    if isinstance(fs, (int, float)) and not isinstance(fs, bool):
        if fs < 0 or fs > 100:
            violations.append({
                "field": "freshness_score", "path": "freshness_score",
                "violation_type": "CUSTOM_RULE",
                "expected": "0.0 to 100.0 inclusive",
                "actual": str(fs),
                "message": "freshness_score '%s' is outside range 0-100" % fs
            })
            ec += 1

    # high_uncertainty consistency check (ERROR)
    ed = data.get("evidence_distribution", {})
    hu = data.get("high_uncertainty")
    if isinstance(ed, dict) and isinstance(hu, bool):
        h_s = (ed.get("grade_H", 0) or 0) + (ed.get("grade_S", 0) or 0)
        p_e = (ed.get("grade_P", 0) or 0) + (ed.get("grade_E", 0) or 0)
        if h_s > p_e and hu is False:
            violations.append({
                "field": "high_uncertainty", "path": "high_uncertainty",
                "violation_type": "CUSTOM_RULE",
                "expected": "true when >50%% claims are [H] or [S]",
                "actual": "false",
                "message": "high_uncertainty is false but (grade_H + grade_S) = %s "
                           "exceeds (grade_P + grade_E) = %s" % (h_s, p_e)
            })
            ec += 1

    # evidence_quality consistency with evidence_distribution (ERROR)
    if isinstance(ed, dict) and isinstance(eq, (int, float)):
        total_pe = (ed.get("grade_P", 0) or 0) + (ed.get("grade_E", 0) or 0)
        if total_pe == 0 and eq > 0:
            violations.append({
                "field": "evidence_quality", "path": "evidence_quality",
                "violation_type": "CUSTOM_RULE",
                "expected": "0.0 when no [P] or [E] claims",
                "actual": str(eq),
                "message": "evidence_quality is %s but there are 0 [P] or [E] claims" % eq
            })
            ec += 1

    # open_questions >= 0 (ERROR)
    oq = data.get("open_questions")
    if isinstance(oq, (int, float)) and oq < 0:
        violations.append({
            "field": "open_questions", "path": "open_questions",
            "violation_type": "CUSTOM_RULE",
            "expected": ">= 0",
            "actual": str(oq),
            "message": "open_questions '%s' is negative" % oq
        })
        ec += 1

    # credit_consumed >= 0 (ERROR)
    cc = data.get("credit_consumed", {})
    if isinstance(cc, dict):
        fc = cc.get("firecrawl")
        if isinstance(fc, (int, float)) and fc < 0:
            violations.append({
                "field": "firecrawl", "path": "credit_consumed.firecrawl",
                "violation_type": "CUSTOM_RULE",
                "expected": ">= 0",
                "actual": str(fc),
                "message": "credit_consumed.firecrawl '%s' is negative" % fc
            })
            ec += 1
        dse = cc.get("dataforseo_usd")
        if isinstance(dse, (int, float)) and dse < 0:
            violations.append({
                "field": "dataforseo_usd", "path": "credit_consumed.dataforseo_usd",
                "violation_type": "CUSTOM_RULE",
                "expected": ">= 0",
                "actual": str(dse),
                "message": "credit_consumed.dataforseo_usd '%s' is negative" % dse
            })
            ec += 1

    # WARNING: calibration_applied + composite_score == composite_score_raw
    cal = data.get("calibration_applied")
    if (isinstance(cal, bool) and cal
            and isinstance(cs, (int, float)) and isinstance(csr, (int, float))
            and cs == csr):
        warnings.append({
            "field": "calibration_applied", "path": "calibration_applied",
            "violation_type": "CUSTOM_RULE",
            "expected": "composite_score differs from raw when calibration is applied",
            "actual": "composite_score=%s, composite_score_raw=%s" % (cs, csr),
            "message": "calibration_applied is true but composite_score (%s) "
                       "equals composite_score_raw (%s)" % (cs, csr)
        })
        wc += 1

    # WARNING: niche_id format check
    nid = data.get("niche_id")
    if isinstance(nid, str) and not re.match(r"^(?:N-\d{3}|CAL-[AB])$", nid):
        warnings.append({
            "field": "niche_id", "path": "niche_id",
            "violation_type": "CUSTOM_RULE",
            "expected": "N-XXX format (e.g., N-001)",
            "actual": nid,
            "message": "niche_id '%s' does not match N-XXX format" % nid
        })
        wc += 1

    return ec, wc


