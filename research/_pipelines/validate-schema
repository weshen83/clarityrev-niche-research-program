def run_custom_validations(data_type, data, violations, warnings):
    """Run data-type-specific custom validation rules."""
    dispatch = {
        "competitor-profile": _custom_cp,
        "review-corpus": _custom_rc,
        "market-sizing": _custom_ms,
        "canvas-frontmatter": _custom_cf,
    }
    fn = dispatch.get(data_type)
    if fn:
        return fn(data, violations, warnings)
    return 0, 0


def _custom_cp(data, violations, warnings):
    """Competitor-profile custom validation rules."""
    ec = wc = 0

    profile = data.get("profile", {})
    if not isinstance(profile, dict):
        violations.append({
            "field": "profile", "path": "profile",
            "violation_type": "CUSTOM_RULE",
            "expected": "object with competitor profile data",
            "actual": "type: %s" % type(profile).__name__,
            "message": "Competitor profile top-level 'profile' is missing or "
                       "not an object -- cannot check nested fields"
        })
        return 1, 0

    # fresh_until consistency with fetch_date + freshness_sla
    fd = data.get("fetch_date")
    fsla = data.get("freshness_sla")
    fu = data.get("fresh_until")
    if all(isinstance(v, str) for v in [fd, fsla, fu]):
        m = re.match(r"^(\d+)d$", fsla)
        if m:
            sla_days = int(m.group(1))
            try:
                fd_dt = datetime.strptime(fd[:10], "%Y-%m-%d")
                fu_dt = datetime.strptime(fu[:10], "%Y-%m-%d")
                exp = fd_dt + timedelta(days=sla_days)
                if abs((fu_dt - exp).days) > 1:
                    violations.append({
                        "field": "fresh_until", "path": "fresh_until",
                        "violation_type": "CUSTOM_RULE",
                        "expected": "~%s (= %s + %s)" % (
                            exp.strftime("%Y-%m-%d"), fd, fsla),
                        "actual": fu,
                        "message": "fresh_until '%s' inconsistent with "
                                   "fetch_date '%s' + freshness_sla '%s'" % (fu, fd, fsla)
                    })
                    ec += 1
            except (ValueError, TypeError):
                pass

    # pricing array: at least 1 entry (WARNING)
    pricing = profile.get("pricing", [])
    if isinstance(pricing, list) and len(pricing) == 0:
        warnings.append({
            "field": "pricing", "path": "profile.pricing",
            "violation_type": "CUSTOM_RULE",
            "expected": "at least 1 pricing tier",
            "actual": "empty pricing array",
            "message": "Pricing array is empty -- at least 1 entry recommended for DEEP depth"
        })
        wc += 1

    # strengths: at least 1 entry (ERROR)
    strengths = profile.get("strengths", [])
    if isinstance(strengths, list) and len(strengths) == 0:
        violations.append({
            "field": "strengths", "path": "profile.strengths",
            "violation_type": "CUSTOM_RULE",
            "expected": "at least 1 strength entry",
            "actual": "empty list",
            "message": "profile.strengths is empty -- at least 1 entry required"
        })
        ec += 1

    # weaknesses: at least 1 entry (ERROR)
    weaknesses = profile.get("weaknesses", [])
    if isinstance(weaknesses, list) and len(weaknesses) == 0:
        violations.append({
            "field": "weaknesses", "path": "profile.weaknesses",
            "violation_type": "CUSTOM_RULE",
            "expected": "at least 1 weakness entry",
            "actual": "empty list",
            "message": "profile.weaknesses is empty -- at least 1 entry required"
        })
        ec += 1

    # source_urls: at least 1 entry (ERROR)
    surls = data.get("source_urls", [])
    if isinstance(surls, list) and len(surls) == 0:
        violations.append({
            "field": "source_urls", "path": "source_urls",
            "violation_type": "CUSTOM_RULE",
            "expected": "at least 1 source URL",
            "actual": "empty list",
            "message": "source_urls is empty -- at least 1 source URL required"
        })
        ec += 1

    # vulnerabilities: at least 1 entry (ERROR)
    vulns = profile.get("vulnerabilities", [])
    if isinstance(vulns, list) and len(vulns) == 0:
        violations.append({
            "field": "vulnerabilities", "path": "profile.vulnerabilities",
            "violation_type": "CUSTOM_RULE",
            "expected": "at least 1 vulnerability entry",
            "actual": "empty list",
            "message": "profile.vulnerabilities is empty -- at least 1 entry required"
        })
        ec += 1

    # freshness_status consistency
    fstat = data.get("freshness_status")
    if isinstance(fstat, str) and isinstance(fu, str):
        try:
            fu_dt = datetime.strptime(fu[:10], "%Y-%m-%d")
            fu_aware = fu_dt.replace(tzinfo=timezone.utc)
            now = datetime.now(timezone.utc)
            exp_status = "FRESH" if now < fu_aware else "STALE"
            if fstat != exp_status:
                violations.append({
                    "field": "freshness_status", "path": "freshness_status",
                    "violation_type": "CUSTOM_RULE",
                    "expected": exp_status,
                    "actual": fstat,
                    "message": "freshness_status is '%s' but fresh_until '%s' "
                               "indicates '%s' (now: %s)" % (
                        fstat, fu, exp_status, now.strftime("%Y-%m-%d"))
                })
                ec += 1
        except (ValueError, TypeError):
            pass

    return ec, wc


def _custom_rc(data, violations, warnings):
    """Review-corpus custom validation rules."""
    ec = wc = 0

    sources = data.get("sources", {})
    total = data.get("total_reviews")
    if isinstance(sources, dict) and isinstance(total, (int, float)):
        src_sum = 0
        for sk in ("g2", "capterra", "reddit"):
            s = sources.get(sk, {})
            if isinstance(s, dict):
                src_sum += s.get("count", 0) or 0
        if src_sum != total:
            violations.append({
                "field": "total_reviews", "path": "total_reviews",
                "violation_type": "CUSTOM_RULE",
                "expected": "sum of source counts (%d)" % src_sum,
                "actual": str(total),
                "message": "total_reviews (%s) does not equal sum of source counts (%d)" % (
                    total, src_sum)
            })
            ec += 1

    reviews = data.get("reviews", [])
    if isinstance(reviews, list):
        seen_ids = set()
        for i, rv in enumerate(reviews):
            if not isinstance(rv, dict):
                continue
            rating = rv.get("rating")
            if isinstance(rating, int) and not isinstance(rating, bool):
                if rating < 1 or rating > 5:
                    violations.append({
                        "field": "rating", "path": "reviews[%d].rating" % i,
                        "violation_type": "CUSTOM_RULE",
                        "expected": "integer between 1 and 5 inclusive",
                        "actual": str(rating),
                        "message": "Review #%d rating '%s' is outside allowed range (1-5)" % (
                            i + 1, rating)
                    })
                    ec += 1
            rid = rv.get("review_id")
            if rid and isinstance(rid, str):
                if rid in seen_ids:
                    violations.append({
                        "field": "review_id", "path": "reviews[%d].review_id" % i,
                        "violation_type": "CUSTOM_RULE",
                        "expected": "unique review_id",
                        "actual": rid,
                        "message": "Duplicate review_id '%s' at reviews[%d]" % (rid, i)
                    })
                    ec += 1
                seen_ids.add(rid)

        if len(reviews) == 0:
            violations.append({
                "field": "reviews", "path": "reviews",
                "violation_type": "CUSTOM_RULE",
                "expected": "at least 1 review entry",
                "actual": "empty reviews array",
                "message": "Review corpus has no review entries"
            })
            ec += 1

    ta = data.get("theme_analysis", {})
    if isinstance(ta, dict):
        for lk in ("top_praise_themes", "top_complaint_themes"):
            tl = ta.get(lk, [])
            if isinstance(tl, list):
                for j, entry in enumerate(tl):
                    if isinstance(entry, dict):
                        pct = entry.get("pct")
                        if isinstance(pct, (int, float)) and (pct < 0 or pct > 100):
                            warnings.append({
                                "field": "pct",
                                "path": "theme_analysis.%s[%d].pct" % (lk, j),
                                "violation_type": "CUSTOM_RULE",
                                "expected": "percentage 0-100",
                                "actual": str(pct),
                                "message": "Theme percentage '%s' is outside expected range 0-100" % pct
                            })
                            wc += 1

    return ec, wc


