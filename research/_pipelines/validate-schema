            "field": "companies", "path": "tam.companies",
            "violation_type": "CUSTOM_RULE",
            "expected": "non-negative integer",
            "actual": str(comp),
            "message": "TAM companies '%s' is negative" % comp
        })
        ec += 1

    tsrc = tam.get("sources", [])
    if isinstance(tsrc, list) and len(tsrc) == 0:
        violations.append({
            "field": "sources", "path": "tam.sources",
            "violation_type": "CUSTOM_RULE",
            "expected": "at least 1 source entry",
