        warnings.append({
            "field": "companies_range", "path": "tam.companies_range",
            "violation_type": "CUSTOM_RULE",
            "expected": "range pattern like '6,000-12,000'",
            "actual": cr,
            "message": "companies_range '%s' does not match expected pattern (e.g., '6,000-12,000')" % cr
        })
        wc += 1

    return ec, wc


def _custom_cf(data, violations, warnings):
    """Canvas-frontmatter custom validation rules."""
    ec = wc = 0

    cs = data.get("composite_score")
    if isinstance(cs, (int, float)) and not isinstance(cs, bool):
        if cs < 0 or cs > 10:
            violations.append({
                "field": "composite_score", "path": "composite_score",
                "violation_type": "CUSTOM_RULE",
                "expected": "0.0 to 10.0 inclusive",
                "actual": str(cs),
                "message": "composite_score '%s' is outside range 0-10" % cs
            })
            ec += 1

    csr = data.get("composite_score_raw")
    if isinstance(csr, (int, float)) and not isinstance(csr, bool):
        if csr < 0 or csr > 10:
            violations.append({
                "field": "composite_score_raw", "path": "composite_score_raw",
                "violation_type": "CUSTOM_RULE",
                "expected": "0.0 to 10.0 inclusive",
                "actual": str(csr),
                "message": "composite_score_raw '%s' is outside range 0-10" % csr
            })
            ec += 1

    scores = data.get("scores", {})
    if isinstance(scores, dict):
        for sf in ("structural_attractiveness", "warm_access",
                    "commercial_viability", "build_feasibility"):
            val = scores.get(sf)
            if isinstance(val, int) and not isinstance(val, bool):
                if val < 1 or val > 10:
                    violations.append({
                        "field": sf, "path": "scores.%s" % sf,
                        "violation_type": "CUSTOM_RULE",
                        "expected": "integer between 1 and 10 inclusive",
                        "actual": str(val),
                        "message": "Sub-score '%s' value %s is outside range 1-10" % (sf, val)
                    })
                    ec += 1

    eq = data.get("evidence_quality")
    if isinstance(eq, (int, float)) and not isinstance(eq, bool):
        if eq < 0 or eq > 100:
            violations.append({
                "field": "evidence_quality", "path": "evidence_quality",
                "violation_type": "CUSTOM_RULE",
                "expected": "0.0 to 100.0 inclusive",
                "actual": str(eq),
                "message": "evidence_quality '%s' is outside range 0-100" % eq
            })
            ec += 1

    fs = data.get("freshness_score")
    if isinstance(fs, (int, float)) and not isinstance(fs, bool):
        if fs < 0 or fs > 100:
            violations.append({
                "field": "freshness_score", "path": "freshness_score",
                "violation_type": "CUSTOM_RULE",
                "expected": "0.0 to 100.0 inclusive",
                "actual": str(fs),
                "message": "freshness_score '%s' is outside range 0-100" % fs
            })
            ec += 1

    ed = data.get("evidence_distribution", {})
    hu = data.get("high_uncertainty")
    if isinstance(ed, dict) and isinstance(hu, bool):
        h_s = (ed.get("grade_H", 0) or 0) + (ed.get("grade_S", 0) or 0)
        p_e = (ed.get("grade_P", 0) or 0) + (ed.get("grade_E", 0) or 0)
        if h_s > p_e and hu is False:
            violations.append({
                "field": "high_uncertainty", "path": "high_uncertainty",
                "violation_type": "CUSTOM_RULE",
                "expected": "true when >50%% claims are [H] or [S]",
                "actual": "false",
                "message": "high_uncertainty is false but (grade_H + grade_S) = %s "
                           "exceeds (grade_P + grade_E) = %s" % (h_s, p_e)
            })
            ec += 1

    if isinstance(ed, dict) and isinstance(eq, (int, float)):
        total_pe = (ed.get("grade_P", 0) or 0) + (ed.get("grade_E", 0) or 0)
        if total_pe == 0 and eq > 0:
            violations.append({
                "field": "evidence_quality", "path": "evidence_quality",
                "violation_type": "CUSTOM_RULE",
                "expected": "0.0 when no [P] or [E] claims",
                "actual": str(eq),
                "message": "evidence_quality is %s but there are 0 [P] or [E] claims" % eq
            })
            ec += 1

    oq = data.get("open_questions")
    if isinstance(oq, (int, float)) and oq < 0:
        violations.append({
            "field": "open_questions", "path": "open_questions",
            "violation_type": "CUSTOM_RULE",
            "expected": ">= 0",
            "actual": str(oq),
            "message": "open_questions '%s' is negative" % oq
        })
        ec += 1

    cc = data.get("credit_consumed", {})
    if isinstance(cc, dict):
        fc = cc.get("firecrawl")
        if isinstance(fc, (int, float)) and fc < 0:
            violations.append({
                "field": "firecrawl", "path": "credit_consumed.firecrawl",
                "violation_type": "CUSTOM_RULE",
                "expected": ">= 0",
                "actual": str(fc),
                "message": "credit_consumed.firecrawl '%s' is negative" % fc
            })
            ec += 1
        dse = cc.get("dataforseo_usd")
        if isinstance(dse, (int, float)) and dse < 0:
            violations.append({
                "field": "dataforseo_usd", "path": "credit_consumed.dataforseo_usd",
                "violation_type": "CUSTOM_RULE",
                "expected": ">= 0",
                "actual": str(dse),
                "message": "credit_consumed.dataforseo_usd '%s' is negative" % dse
            })
            ec += 1

    cal = data.get("calibration_applied")
    if (isinstance(cal, bool) and cal
            and isinstance(cs, (int, float)) and isinstance(csr, (int, float))
            and cs == csr):
        warnings.append({
            "field": "calibration_applied", "path": "calibration_applied",
            "violation_type": "CUSTOM_RULE",
            "expected": "composite_score differs from raw when calibration is applied",
            "actual": "composite_score=%s, composite_score_raw=%s" % (cs, csr),
            "message": "calibration_applied is true but composite_score (%s) "
                       "equals composite_score_raw (%s)" % (cs, csr)
        })
        wc += 1

    nid = data.get("niche_id")
    if isinstance(nid, str) and not re.match(r"^(?:N-\d{3}|CAL-[AB])$", nid):
        warnings.append({
            "field": "niche_id", "path": "niche_id",
            "violation_type": "CUSTOM_RULE",
            "expected": "N-XXX format (e.g., N-001)",
            "actual": nid,
            "message": "niche_id '%s' does not match N-XXX format" % nid
        })
        wc += 1

    return ec, wc


