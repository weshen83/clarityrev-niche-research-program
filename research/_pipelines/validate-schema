def load_and_validate_schema(data_type, schema_dir=None):
    """Load the schema definition file for the given data type."""
    if schema_dir is None:
        schema_dir = SCHEMAS_DIR

    schema_filename = DATA_TYPE_SCHEMA_MAP[data_type]
    schema_path = schema_dir / schema_filename

    if not schema_path.exists():
        emit_log("ERROR", "Schema file not found: %s" % schema_path)
        emit_result(ExitCode.INTERNAL_ERROR, {
            "error": "Schema file not found: %s" % str(schema_path),
            "schema_file": repo_relative_path(schema_path)
        })

    try:
        schema_data = load_yaml_safe(schema_path)
    except ValueError as e:
        emit_log("ERROR", "Schema file corrupted: %s - %s" % (schema_path, e))
        emit_result(ExitCode.INTERNAL_ERROR, {
            "error": "Schema file corrupted: %s" % str(schema_path),
            "details": str(e),
            "schema_file": repo_relative_path(schema_path),
        })
    if schema_data is None:
        emit_log("ERROR", "Failed to load schema (empty or missing): %s" % schema_path)
        emit_result(ExitCode.INTERNAL_ERROR, {
            "error": "Failed to load schema: %s" % str(schema_path),
            "schema_file": repo_relative_path(schema_path)
        })

    _validate_schema_structure(schema_data, schema_path)

    schema_meta = schema_data.get("schema", {})
    emit_log("INFO", "Loaded schema: %s v%s" % (
        schema_meta.get("name", schema_filename),
        schema_meta.get("version", "?")
    ))

    return schema_data, schema_path


def _validate_schema_structure(schema_data, schema_path):
    """Validate that the loaded schema has the required structure."""
    if not isinstance(schema_data, dict):
        raise ValueError("Schema at %s must be a mapping (dict), got %s" % (
            schema_path, type(schema_data).__name__))

    if "schema" not in schema_data:
        raise ValueError("Schema at %s missing required top-level key 'schema'" % schema_path)

    schema_meta = schema_data["schema"]
    if not isinstance(schema_meta, dict):
        raise ValueError("Schema at %s.schema must be a mapping, got %s" % (
            schema_path, type(schema_meta).__name__))

    for key in ("name", "version", "source"):
        if key not in schema_meta:
            raise ValueError("Schema at %s missing schema.%s" % (schema_path, key))

    if "fields" not in schema_data or not isinstance(schema_data["fields"], list):
        raise ValueError("Schema at %s missing or invalid 'fields' list" % schema_path)

    for i, field in enumerate(schema_data["fields"]):
        if not isinstance(field, dict):
            raise ValueError("Schema at %s field[%d] must be a mapping, got %s" % (
                schema_path, i, type(field).__name__))
        for key in ("field", "type", "required"):
            if key not in field:
                raise ValueError("Schema at %s field[%d] ('%s') missing required key '%s'" % (
                    schema_path, i, field.get("field", "?"), key))

    return True


def single_file_main():
    """
    Main entry point for single-file validate-schema mode.
    (Backward-compatible with the original interface.)
    """
    # Extract --quiet / --agent-mode
    args = sys.argv[1:]
    quiet_mode = "--quiet" in args
    if quiet_mode:
        args.remove("--quiet")
    agent_mode = "--agent-mode" in args
    if agent_mode:
        args.remove("--agent-mode")
    if agent_mode:
        set_agent_mode(True)
    elif quiet_mode:
        set_quiet_mode(True)
    sys.argv = [sys.argv[0]] + args

    try:
        data_type, file_path, schema_dir, dry_run = parse_validate_args()

        cwd = str(Path.cwd())
        rel = str(file_path)
        if rel.startswith(cwd):
            rel = rel[len(cwd)+1:]
        emit_log("INFO", "Starting validation: %s -> %s" % (data_type, rel))

        schema_data, schema_path = load_and_validate_schema(data_type, schema_dir)

        emit_log("INFO", "Loading data file: %s" % file_path)
        data = load_yaml_safe(file_path)
        if data is None:
            emit_log("ERROR", "Data file is empty: %s" % file_path)
            emit_result(ExitCode.INVALID_INPUT, {
                "verdict": "FAIL", "data_type": data_type,
                "file_path": repo_relative_path(file_path),
                "schema_file": repo_relative_path(schema_path),
                "error": "Data file is empty: %s" % file_path
            })
        if not isinstance(data, dict):
            emit_log("ERROR", "Data file root must be a mapping (dict), got %s" % type(data).__name__)
            emit_result(ExitCode.INVALID_INPUT, {
                "verdict": "FAIL", "data_type": data_type,
                "file_path": repo_relative_path(file_path),
                "schema_file": repo_relative_path(schema_path),
                "error": "Data file root must be a mapping (dict), got %s" % type(data).__name__
            })

        schema_fields = schema_data.get("fields", [])
        field_count = _count_fields(schema_fields)

        if dry_run:
            sname = schema_data.get("schema", {}).get("name", "Unknown")
            emit_log("INFO", "[DRY-RUN] Would validate '%s' against '%s'" % (rel, sname))
            emit_log("INFO", "[DRY-RUN] Schema: %s" % schema_path)
            emit_log("INFO", "[DRY-RUN] Would perform %d field checks + custom rules for '%s'" % (
                field_count, data_type))
            emit_log("INFO", "[DRY-RUN] Dry run complete")
            emit_result(ExitCode.SUCCESS, {
                "verdict": "DRY_RUN", "data_type": data_type,
                "file_path": repo_relative_path(file_path),
                "schema_file": repo_relative_path(schema_path),
                "dry_run": True, "field_checks_planned": field_count,
                "message": "Dry run complete. --dry-run is informative only."
            })

        emit_log("INFO", "Running %d field checks..." % field_count)
        violations = []
        warnings_list = []
        required_present = []
        optional_missing = []

        validate_recursive(data, schema_fields, "",
                           violations, warnings_list,
                           required_present, optional_missing)

        emit_log("INFO", "Base checks: %d present, %d required missing, "
                         "%d type, %d enum, %d range" % (
            len(required_present),
            len(_count_by_type(violations, "REQUIRED_MISSING")),
            len(_count_by_type(violations, "TYPE_MISMATCH")),
            len(_count_by_type(violations, "ENUM_VIOLATION")),
            len(_count_by_type(violations, "RANGE_VIOLATION")),
        ))

        emit_log("INFO", "Running custom validation rules for '%s'..." % data_type)
        custom_err, custom_warn = run_custom_validations(data_type, data, violations, warnings_list)
        emit_log("INFO", "Custom rules: %d errors, %d warnings" % (custom_err, custom_warn))

        exit_code, result = assemble_verdict(
            violations, warnings_list,
            required_present, optional_missing,
            data_type, file_path, schema_path
        )

        emit_log("INFO", "Verdict: %s (exit %d)" % (result["verdict"], exit_code.value))
        emit_result(exit_code, result)

    except ValueError as e:
        emit_log("FATAL", "Validation error: %s" % e)
        emit_result(ExitCode.INTERNAL_ERROR, {
            "error": str(e),
            "traceback": traceback.format_exc(),
        })
    except Exception as e:
        emit_log("FATAL", "Unexpected error: %s" % e)
        emit_result(ExitCode.INTERNAL_ERROR, {
            "error": "Unexpected error: %s" % e,
            "traceback": traceback.format_exc(),
        })


