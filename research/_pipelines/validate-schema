def validate_single_file(file_path: Path, data_type: str, schemas_dir: Path,
                         verbose: bool):
    """
    Validate a single YAML file against the schema for data_type.

    Returns (exit_code, result_dict).
    """
    schema_filename = DATA_TYPE_SCHEMA_MAP.get(data_type)
    if not schema_filename:
        return ExitCode.INVALID_INPUT, {
            "error": f"No schema for data type '{data_type}'",
            "file": repo_relative_path(file_path),
        }

    schema_path = schemas_dir / schema_filename
    if not schema_path.exists():
        return ExitCode.INTERNAL_ERROR, {
            "error": f"Schema not found: {schema_path}",
            "file": repo_relative_path(schema_path),
        }

    try:
        schema_data = load_yaml_safe(schema_path)
    except ValueError as e:
        return ExitCode.INTERNAL_ERROR, {
            "error": f"Schema corrupted: {e}",
            "schema_file": repo_relative_path(schema_path),
        }

    if schema_data is None or not isinstance(schema_data, dict):
        return ExitCode.INTERNAL_ERROR, {
            "error": "Schema is empty or not a dict",
            "schema_file": repo_relative_path(schema_path),
        }

    try:
        data = load_yaml_safe(file_path)
    except ValueError as e:
        emit_log("ERROR", f"YAML parse error in {file_path}: {e}")
        return ExitCode.INTERNAL_ERROR, {
            "error": f"YAML parse error: {e}",
            "file": repo_relative_path(file_path),
        }

    if data is None:
        return ExitCode.INVALID_INPUT, {
            "error": "Data file is empty",
            "file": repo_relative_path(file_path),
        }

    if not isinstance(data, dict):
        return ExitCode.INVALID_INPUT, {
            "error": f"Data file root must be a dict, got {type(data).__name__}",
            "file": repo_relative_path(file_path),
        }

    schema_fields = schema_data.get("fields", [])
    violations = []
    warnings_list = []
    required_present = []
    optional_missing = []

    # Use existing recursive validation
    validate_recursive(data, schema_fields, "",
                       violations, warnings_list,
                       required_present, optional_missing)

    # Custom validation for known data types
    custom_err, custom_warn = run_custom_validations(
        data_type, data, violations, warnings_list)

    ec, result = assemble_verdict(
        violations, warnings_list,
        required_present, optional_missing,
        data_type, file_path, schema_path)
    result["custom_errors"] = custom_err
    result["custom_warnings"] = custom_warn
    result["file"] = repo_relative_path(file_path)
    result["schema_file"] = repo_relative_path(schema_path)
    result["schema_name"] = schema_data.get("schema", {}).get("name", schema_filename)

    if verbose:
        result["violations"] = violations
        result["warnings"] = warnings_list

    return ec, result


def validate_recursive(data, schema_fields, path_prefix="",
                       violations=None, warnings=None,
                       required_present=None, optional_missing=None):
    """
    Recursively validate data against a list of schema field definitions.
    (Copied from validate-schema single-file mode for self-contained operation.)
    """
    if violations is None:
        violations = []
    if warnings is None:
        warnings = []
    if required_present is None:
        required_present = []
    if optional_missing is None:
        optional_missing = []

    if not isinstance(data, dict):
        return

    for field_spec in schema_fields:
        field_name = field_spec.get("field")
        if not field_name:
            continue

        full_path = "%s.%s" % (path_prefix, field_name) if path_prefix else field_name
        value = data.get(field_name)

        required = field_spec.get("required", False)
        type_str = field_spec.get("type", "")
        enum_values = field_spec.get("enum")
        min_val = field_spec.get("min")
        max_val = field_spec.get("max")
        min_items = field_spec.get("min_items")

        children = field_spec.get("fields") or field_spec.get("children")
        item_schema = field_spec.get("items") or field_spec.get("item_schema")

        # -- 1. REQUIRED check --
        if required and (value is None or (isinstance(value, str) and value.strip() == "")):
            violations.append({
                "field": field_name,
                "path": full_path,
                "violation_type": "REQUIRED_MISSING",
                "expected": type_str,
                "actual": "None" if value is None else "empty string",
                "message": "Required field '%s' is missing or empty" % full_path
            })
            continue

        if required and value is not None:
            required_present.append(full_path)

        if not required and (value is None or (isinstance(value, str) and value.strip() == "")):
            optional_missing.append(full_path)
            continue

        # -- 2. TYPE check --
        type_ok = _check_value_type(value, type_str)
        if not type_ok:
            violations.append({
                "field": field_name,
                "path": full_path,
                "violation_type": "TYPE_MISMATCH",
                "expected": type_str,
                "actual": type(value).__name__,
                "message": "Field '%s' expected type '%s' but got %s" % (
                    full_path, type_str, type(value).__name__)
            })
            continue

        # -- 3. String FORMAT check --
        if (isinstance(value, str) and "string" in type_str.lower()
                and type_str.lower() != "string"):
            is_valid, err_msg = _validate_string_format(value, type_str)
            if not is_valid:
                violations.append({
                    "field": field_name,
                    "path": full_path,
                    "violation_type": "FORMAT_VIOLATION",
                    "expected": "valid %s format" % type_str,
                    "actual": value,
                    "message": err_msg or "Field '%s' does not match expected format for '%s'" % (
                        full_path, type_str)
                })

        # -- 4. ENUM check --
        if enum_values and value is not None and value not in enum_values:
            violations.append({
                "field": field_name,
                "path": full_path,
                "violation_type": "ENUM_VIOLATION",
                "expected": list(enum_values),
                "actual": str(value),
                "message": "Field '%s' value '%s' is not in allowed values: %s" % (
                    full_path, value, list(enum_values))
            })

        # -- 5. NUMERIC RANGE check --
        if isinstance(value, (int, float)) and not isinstance(value, bool):
            if min_val is not None and value < min_val:
                violations.append({
                    "field": field_name,
                    "path": full_path,
                    "violation_type": "RANGE_VIOLATION",
                    "expected": ">= %s" % min_val,
                    "actual": value,
                    "message": "Field '%s' value %s is below minimum %s" % (
                        full_path, value, min_val)
                })
            if max_val is not None and value > max_val:
                violations.append({
                    "field": field_name,
                    "path": full_path,
                    "violation_type": "RANGE_VIOLATION",
                    "expected": "<= %s" % max_val,
                    "actual": value,
                    "message": "Field '%s' value %s exceeds maximum %s" % (
                        full_path, value, max_val)
                })

        # -- 6. min_items check for array fields --
        if (isinstance(value, list) and min_items is not None
                and len(value) < min_items):
            warnings.append({
                "field": field_name,
                "path": full_path,
                "violation_type": "MIN_ITEMS",
                "expected": ">= %d items" % min_items,
                "actual": "%d items" % len(value),
                "message": "Field '%s' has %d items, minimum is %d" % (
                    full_path, len(value), min_items)
            })

        # -- 7. NESTED: recurse into object children --
        if children and isinstance(value, dict):
            validate_recursive(value, children, full_path,
                               violations, warnings,
                               required_present, optional_missing)

        # -- 8. NESTED: recurse into array items --
        elif item_schema and isinstance(value, list):
            _validate_array_items(value, item_schema, field_name, full_path,
                                  violations, warnings,
                                  required_present, optional_missing)


def _validate_array_items(items, item_schema, field_name, full_path,
                          violations, warnings,
                          required_present, optional_missing):
    """Validate each item in an array against the item schema."""
    # Handle trace-map-style item_schema (list of field defs directly)
    if isinstance(item_schema, list):
        item_schema = {"type": "object", "fields": item_schema}

    items_type = item_schema.get("type", "").lower().strip()
    items_required = item_schema.get("required", [])
    item_fields = item_schema.get("fields") or item_schema.get("children") or []

    # Merge items.required list into individual field specs
    enhanced_fields = []
    for item_field in item_fields:
        enhanced = dict(item_field)
        fn = enhanced.get("field")
        if fn and fn in items_required:
            enhanced["required"] = True
        enhanced_fields.append(enhanced)

    for i, item in enumerate(items):
        item_path = "%s[%d]" % (full_path, i)

        if items_type in ("object", "dict") and not isinstance(item, dict):
            violations.append({
                "field": field_name,
                "path": item_path,
                "violation_type": "TYPE_MISMATCH",
                "expected": "object",
                "actual": type(item).__name__,
                "message": "Array item at '%s' expected object, got %s" % (
                    item_path, type(item).__name__)
            })
            continue

        if enhanced_fields and isinstance(item, dict):
            validate_recursive(item, enhanced_fields, item_path,
                               violations, warnings,
                               required_present, optional_missing)


