def validate_evidence_claims(claims_path: Path):
    """
    Validate evidence-claims.json structure (if it exists).

    Expected structure: a JSON list where each entry is an object with at
    least a 'claim_id' field.  Optional file — returns PASS if not found.
    """
    if not claims_path.exists():
        emit_log("INFO", f"evidence-claims.json not found at {claims_path} — skipping")
        return ExitCode.SUCCESS, {
            "verdict": "NOT_FOUND",
            "file": repo_relative_path(claims_path),
            "note": "evidence-claims.json not found, skipping",
        }

    violations = []

    try:
        with open(claims_path, "r") as f:
            data = json_module.load(f)
    except (json_module.JSONDecodeError, OSError) as e:
        emit_log("ERROR", f"evidence-claims.json corrupted: {e}")
        return ExitCode.INTERNAL_ERROR, {
            "file": repo_relative_path(claims_path),
            "error": f"JSON parse error: {e}",
        }

    if not isinstance(data, list):
        violations.append({
            "field": "(root)", "path": "(root)",
            "violation_type": "TYPE_MISMATCH",
            "expected": "list", "actual": type(data).__name__,
            "message": "evidence-claims.json root must be a list",
        })
    else:
        for i, entry in enumerate(data):
            if not isinstance(entry, dict):
                violations.append({
                    "field": f"[{i}]", "path": f"[{i}]",
                    "violation_type": "TYPE_MISMATCH",
                    "expected": "dict", "actual": type(entry).__name__,
                    "message": f"Entry [{i}] must be a dict",
                })
                continue
            if "claim_id" not in entry:
                violations.append({
                    "field": "claim_id", "path": f"[{i}].claim_id",
                    "violation_type": "REQUIRED_MISSING",
                    "expected": "present", "actual": "missing",
                    "message": f"Entry [{i}] missing required 'claim_id'",
                })

    if violations:
        result = {
            "verdict": "FAIL",
            "file": repo_relative_path(claims_path),
            "violations": len(violations),
            "violations_detail": violations,
        }
        return ExitCode.BLOCKED, result

    return ExitCode.SUCCESS, {
        "verdict": "PASS",
        "file": repo_relative_path(claims_path),
        "claims_validated": len(data),
    }


