# TRACE-MAP VALIDATION (against trace-map-schema.yaml)
# ============================================================================

# Minimal required fields for trace-map.yaml claims structure
TRACE_MAP_REQUIRED_TOP = frozenset({"niche_id", "generated_by", "generated_at",
                                     "methodology_version", "claims"})
TRACE_MAP_CLAIM_REQUIRED = frozenset({"claim_id", "claim_text", "canvas_section",
                                       "evidence_grade", "sources"})
TRACE_MAP_SOURCE_REQUIRED = frozenset({"source_file", "fetch_date",
                                        "freshness_status", "fresh_until"})


def validate_trace_map_structure(trace_map_path: Path):
    """
    Validate trace-map.yaml directly against the expected structure defined
    in trace-map-schema.yaml.  Handles the list-format item_schema that
    differs from the competitor-profile schema format.

    Returns (exit_code, result_dict).
    """
    violations = []
    warnings_list = []

    try:
        data = load_yaml_safe(trace_map_path)
    except ValueError as e:
        emit_log("ERROR", f"trace-map.yaml corrupted: {e}")
        return ExitCode.INTERNAL_ERROR, {
            "file": repo_relative_path(trace_map_path),
            "error": f"trace-map.yaml corrupted: {e}",
        }

    if data is None:
        emit_log("WARNING", "trace-map.yaml not found or empty")
        return ExitCode.INVALID_INPUT, {
            "file": repo_relative_path(trace_map_path),
            "error": "trace-map.yaml not found or empty",
        }

    if not isinstance(data, dict):
        violations.append({
            "field": "(root)", "path": "(root)",
            "violation_type": "TYPE_MISMATCH",
            "expected": "dict", "actual": type(data).__name__,
            "message": "trace-map.yaml root must be a dict",
        })
        # Check claims section with relaxed requirements (minimal)

    # Check top-level fields
    if isinstance(data, dict):
        for key in TRACE_MAP_REQUIRED_TOP:
            if key not in data or data[key] is None:
                violations.append({
                    "field": key, "path": key,
                    "violation_type": "REQUIRED_MISSING",
                    "expected": "present", "actual": "missing",
                    "message": f"Required top-level field '{key}' is missing",
                })

        # Validate claims array
        claims = data.get("claims", [])
        if not isinstance(claims, list):
            violations.append({
                "field": "claims", "path": "claims",
                "violation_type": "TYPE_MISMATCH",
                "expected": "list", "actual": type(claims).__name__,
                "message": "'claims' must be a list",
            })
        else:
            if len(claims) == 0:
                warnings_list.append({
                    "field": "claims", "path": "claims",
                    "violation_type": "MIN_ITEMS",
                    "expected": ">= 1", "actual": "0",
                    "message": "Claims list is empty",
                })
            for i, claim in enumerate(claims):
                if not isinstance(claim, dict):
                    violations.append({
                        "field": "claims", "path": f"claims[{i}]",
                        "violation_type": "TYPE_MISMATCH",
                        "expected": "dict", "actual": type(claim).__name__,
                        "message": f"claims[{i}] must be a dict",
                    })
                    continue
                for ckey in TRACE_MAP_CLAIM_REQUIRED:
                    if ckey not in claim or claim[ckey] is None:
                        violations.append({
                            "field": ckey, "path": f"claims[{i}].{ckey}",
                            "violation_type": "REQUIRED_MISSING",
                            "expected": "present", "actual": "missing",
                            "message": f"claims[{i}] missing required '{ckey}'",
                        })
                # Validate evidence_grade enum
                eg = claim.get("evidence_grade")
                if eg and eg not in ("[P]", "[E]", "[H]", "[S]"):
                    violations.append({
                        "field": "evidence_grade", "path": f"claims[{i}].evidence_grade",
                        "violation_type": "ENUM_VIOLATION",
                        "expected": "[P], [E], [H], [S]", "actual": str(eg),
                        "message": f"claims[{i}] evidence_grade '{eg}' not in [P]/[E]/[H]/[S]",
                    })
                # Validate sources
                sources = claim.get("sources", [])
                if not isinstance(sources, list):
                    violations.append({
                        "field": "sources", "path": f"claims[{i}].sources",
                        "violation_type": "TYPE_MISMATCH",
                        "expected": "list", "actual": type(sources).__name__,
                        "message": f"claims[{i}].sources must be a list",
                    })
                else:
                    for j, src in enumerate(sources):
                        if not isinstance(src, dict):
                            violations.append({
                                "field": "sources", "path": f"claims[{i}].sources[{j}]",
                                "violation_type": "TYPE_MISMATCH",
                                "expected": "dict", "actual": type(src).__name__,
                                "message": f"claims[{i}].sources[{j}] must be a dict",
                            })
                            continue
                        for skey in TRACE_MAP_SOURCE_REQUIRED:
                            if skey not in src or src[skey] is None:
                                violations.append({
                                    "field": skey, "path": f"claims[{i}].sources[{j}].{skey}",
                                    "violation_type": "REQUIRED_MISSING",
                                    "expected": "present", "actual": "missing",
                                    "message": f"claims[{i}].sources[{j}] missing '{skey}'",
                                })
                        # Validate freshness_status
                        fs = src.get("freshness_status")
                        if fs and fs not in ("FRESH", "STALE", "EXPIRED"):
                            violations.append({
                                "field": "freshness_status",
                                "path": f"claims[{i}].sources[{j}].freshness_status",
                                "violation_type": "ENUM_VIOLATION",
                                "expected": "FRESH, STALE, EXPIRED", "actual": str(fs),
                                "message": f"freshness_status '{fs}' not valid",
                            })

    # Assemble verdict
    has_blocking = any(v["violation_type"] in (
        "REQUIRED_MISSING", "TYPE_MISMATCH", "ENUM_VIOLATION") for v in violations)
    has_warnings = bool(warnings_list)

    if has_blocking:
        verdict = "FAIL"
        exit_code = ExitCode.BLOCKED
    elif has_warnings:
        verdict = "PASS_WITH_WARNINGS"
        exit_code = ExitCode.WARNING
    else:
        verdict = "PASS"
        exit_code = ExitCode.SUCCESS

    result = {
        "verdict": verdict,
        "schema_used": "trace-map-schema.yaml",
        "file": repo_relative_path(trace_map_path),
        "violations": len(violations),
        "warnings": len(warnings_list),
    }
    if violations:
        result["violations_detail"] = violations
    if warnings_list:
        result["warnings_detail"] = warnings_list

    return exit_code, result


