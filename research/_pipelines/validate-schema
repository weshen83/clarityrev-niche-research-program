def _count_by_type(violations, vtype):
    """Count violations of a specific type."""
    return [v for v in violations if v["violation_type"] == vtype]


def assemble_verdict(violations, warnings,
                     required_present, optional_missing,
                     data_type, file_path, schema_path):
    """
    Assemble the validation result and determine the verdict.

    Verdict logic (IMPLEMENTATION-SPEC.md S5.2 Step 4):
    - REQUIRED_MISSING, TYPE_MISMATCH, ENUM_VIOLATION, RANGE_VIOLATION,
      FORMAT_VIOLATION, or CUSTOM_RULE ERROR -> FAIL (exit 1)
    - Only optional missing and warnings -> PASS_WITH_WARNINGS (exit 2)
    - Nothing -> PASS (exit 0)
    """
    rm = _count_by_type(violations, "REQUIRED_MISSING")
    tv = _count_by_type(violations, "TYPE_MISMATCH")
    ev = _count_by_type(violations, "ENUM_VIOLATION")
    rv = _count_by_type(violations, "RANGE_VIOLATION")
    fv = _count_by_type(violations, "FORMAT_VIOLATION")
    cv = _count_by_type(violations, "CUSTOM_RULE")

    has_blocking = bool(rm or tv or ev or rv or fv or cv)
    has_warnings_only = bool(optional_missing or warnings)

    if has_blocking:
        verdict = "FAIL"
        # BLOCKED is used here because the pipeline should not proceed
        # with invalid data (IMPLEMENTATION-SPEC.md S5.2 Step 4).
        exit_code = ExitCode.BLOCKED
    elif has_warnings_only:
        verdict = "PASS_WITH_WARNINGS"
        exit_code = ExitCode.WARNING
    else:
        verdict = "PASS"
        exit_code = ExitCode.SUCCESS

    result = {
        "verdict": verdict,
        "data_type": data_type,
        "file_path": repo_relative_path(file_path),
        "schema_file": repo_relative_path(schema_path),
        "required_fields_present": len(required_present),
        "required_fields_missing": len(rm),
        "optional_fields_missing": len(optional_missing),
        "enum_violations": len(ev),
        "type_violations": len(tv),
        "range_violations": len(rv),
        "format_violations": len(fv),
        "custom_rule_violations": len(cv),
    }

    if warnings:
        result["warnings"] = warnings
    if violations:
        result["violations"] = violations

    return exit_code, result


def _count_fields(schema_fields):
    """Count total field checks (including nested) for dry-run display."""
    count = 0
    for field in schema_fields:
        count += 1
        children = field.get("fields") or field.get("children")
        if children:
            count += _count_fields(children)
        items = field.get("items") or field.get("item_schema")
        if items:
            iff = items.get("fields") or items.get("children")
            if iff:
                count += _count_fields(iff)
    return count


# ============================================================================
# MAIN ENTRY POINT
# ============================================================================

def main():
    """
    Main entry point for validate-schema.

    Flow (from IMPLEMENTATION-SPEC.md S5.2):
    1. Parse arguments
    2. Load and validate schema
    3. Load data file (YAML)
    3b. Dry-run mode: report what would be checked
    4. Run base field-by-field validation (recursive)
    5. Run custom data-type-specific validation
    6. Assemble result with verdict
    7. Emit structured JSON to stdout
    """
    # ── Extract --quiet / --agent-mode (consistent with preflight-check) ──
    args = sys.argv[1:]
    quiet_mode = "--quiet" in args
    if quiet_mode:
        args.remove("--quiet")
    agent_mode = "--agent-mode" in args
    if agent_mode:
        args.remove("--agent-mode")
    if agent_mode:
        set_agent_mode(True)
    elif quiet_mode:
        set_quiet_mode(True)
    sys.argv = [sys.argv[0]] + args

    try:
        # Step 1
        data_type, file_path, schema_dir, dry_run = parse_validate_args()

        cwd = str(Path.cwd())
        rel = str(file_path)
        if rel.startswith(cwd):
            rel = rel[len(cwd)+1:]
        emit_log("INFO", "Starting validation: %s -> %s" % (data_type, rel))

        # Step 2
        schema_data, schema_path = load_and_validate_schema(data_type, schema_dir)

        # Step 3
        emit_log("INFO", "Loading data file: %s" % file_path)
        data = load_yaml_safe(file_path)
        if data is None:
            emit_log("ERROR", "Data file is empty: %s" % file_path)
            emit_result(ExitCode.INVALID_INPUT, {
                "verdict": "FAIL", "data_type": data_type,
                "file_path": repo_relative_path(file_path), "schema_file": repo_relative_path(schema_path),
                "error": "Data file is empty: %s" % file_path
            })
            return None  # Defensive: emit_result calls sys.exit(), but guards against future refactor
        if not isinstance(data, dict):
            emit_log("ERROR", "Data file root must be a mapping (dict), got %s" % type(data).__name__)
            emit_result(ExitCode.INVALID_INPUT, {
                "verdict": "FAIL", "data_type": data_type,
                "file_path": repo_relative_path(file_path), "schema_file": repo_relative_path(schema_path),
                "error": "Data file root must be a mapping (dict), got %s" % type(data).__name__
            })
            return None  # Defensive: emit_result calls sys.exit(), but guards against future refactor

        schema_fields = schema_data.get("fields", [])
        field_count = _count_fields(schema_fields)

        # Step 3b: Dry-run
        if dry_run:
            sname = schema_data.get("schema", {}).get("name", "Unknown")
            emit_log("INFO", "[DRY-RUN] Would validate '%s' against '%s'" % (rel, sname))
            emit_log("INFO", "[DRY-RUN] Schema: %s" % schema_path)
            emit_log("INFO", "[DRY-RUN] Would perform %d field checks + custom rules for '%s'" % (
                field_count, data_type))
            emit_log("INFO", "[DRY-RUN] Dry run complete")
            emit_result(ExitCode.SUCCESS, {
                "verdict": "DRY_RUN", "data_type": data_type,
                "file_path": repo_relative_path(file_path), "schema_file": repo_relative_path(schema_path),
                "dry_run": True, "field_checks_planned": field_count,
                "message": "Dry run complete. --dry-run is informative only."
            })

        # Step 4: Base field validation
        emit_log("INFO", "Running %d field checks..." % field_count)
        violations = []
        warnings_list = []
        required_present = []
        optional_missing = []

        validate_recursive(data, schema_fields, "",
                           violations, warnings_list,
                           required_present, optional_missing)

        emit_log("INFO", "Base checks: %d present, %d required missing, "
                         "%d type, %d enum, %d range" % (
            len(required_present),
            len(_count_by_type(violations, "REQUIRED_MISSING")),
            len(_count_by_type(violations, "TYPE_MISMATCH")),
            len(_count_by_type(violations, "ENUM_VIOLATION")),
            len(_count_by_type(violations, "RANGE_VIOLATION")),
        ))

        # Step 5: Custom validation
        emit_log("INFO", "Running custom validation rules for '%s'..." % data_type)
        custom_err, custom_warn = run_custom_validations(data_type, data, violations, warnings_list)
        emit_log("INFO", "Custom rules: %d errors, %d warnings" % (custom_err, custom_warn))

        # Step 6: Assemble
        exit_code, result = assemble_verdict(
            violations, warnings_list,
            required_present, optional_missing,
            data_type, file_path, schema_path
        )

        # Step 7: Emit
        emit_log("INFO", "Verdict: %s (exit %d)" % (result["verdict"], exit_code.value))
        emit_result(exit_code, result)

    except ValueError as e:
        emit_log("FATAL", "Validation error: %s" % e)
        emit_result(ExitCode.INTERNAL_ERROR, {
            "error": str(e),
            "traceback": traceback.format_exc(),
            "data_type": sys.argv[1] if len(sys.argv) > 1 else "?",
            "file_path": sys.argv[2] if len(sys.argv) > 2 else "?"
        })
    except Exception as e:
        emit_log("FATAL", "Unexpected error: %s" % e)
        emit_result(ExitCode.INTERNAL_ERROR, {
            "error": "Unexpected error: %s" % e,
            "traceback": traceback.format_exc(),
            "data_type": sys.argv[1] if len(sys.argv) > 1 else "?",
            "file_path": sys.argv[2] if len(sys.argv) > 2 else "?"
        })


if __name__ == "__main__":
    main()
