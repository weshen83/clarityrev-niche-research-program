# ============================================================================

_STRING_SUBTYPES = frozenset({
    "string (url)", "string (iso 8601 date)", "string (duration)",
    "string (path)",
})


def _check_value_type(value, type_str):
    """Check that value matches the expected type_str."""
    if type_str is None:
        return True

    type_lower = type_str.lower().strip()

    if type_lower.startswith("array of "):
        item_type = type_lower[9:].strip()
        if not isinstance(value, list):
            return False
        return all(_check_value_type(v, item_type) for v in value)

    if type_lower in _STRING_SUBTYPES:
        return isinstance(value, str)
    elif type_lower == "string":
        return isinstance(value, str)
    elif type_lower == "integer":
        return isinstance(value, int) and not isinstance(value, bool)
    elif type_lower in ("number", "float"):
        return isinstance(value, (int, float)) and not isinstance(value, bool)
    elif type_lower == "boolean":
        return isinstance(value, bool)
    elif type_lower in ("list", "array"):
        return isinstance(value, list)
    elif type_lower in ("dict", "object"):
        return isinstance(value, dict)

    return True


def _validate_string_format(value, type_str):
    """Validate string subtype format."""
    type_lower = type_str.lower().strip()

    if type_lower == "string (iso 8601 date)":
        if not isinstance(value, str):
            return False, "Not a string"
        if re.match(r"^\d{4}-\d{2}-\d{2}$", value):
            return True, None
        try:
            datetime.fromisoformat(value)
            return True, None
        except ValueError:
            return False, "'%s' is not a valid ISO 8601 date (expected YYYY-MM-DD)" % value

    elif type_lower == "string (url)":
        if not isinstance(value, str):
            return False, "Not a string"
        parsed = urlparse(value)
        if parsed.scheme in ("http", "https") and bool(parsed.netloc):
            return True, None
        return False, "'%s' is not a valid URL (expected http/https scheme)" % value

    elif type_lower == "string (duration)":
        if not isinstance(value, str):
            return False, "Not a string"
        if re.match(r"^\d+d$", value):
            return True, None
        return False, "'%s' is not a valid duration (expected format like '90d')" % value

    elif type_lower == "string (path)":
        return isinstance(value, str), None

    return True, None


